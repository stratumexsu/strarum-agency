---
import Card from '../ui/Card.astro';
import Button from '../ui/Button.astro';
---

<div class="below-fold px-6 py-10 md:py-24 bg-white text-primary relative min-h-0 md:min-h-[calc(100dvh-5rem)] flex flex-col justify-center overflow-hidden">
  <!-- Ambient background glow -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-accent/10 rounded-full blur-[120px] pointer-events-none -z-10" style="will-change: transform; transform: translateZ(0);"></div>
  <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[100px] pointer-events-none -z-10" style="will-change: transform; transform: translateZ(0);"></div>

  <div class="max-w-6xl mx-auto z-10 relative w-full">
    <div class="text-center mb-8 md:mb-12 reveal">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/5 border border-primary/10 mb-4 md:mb-6 select-none cursor-default">
        <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
        <span class="text-[11px] font-bold text-primary/70 uppercase tracking-wider">Проблемы</span>
      </div>
      <h2 class="text-3xl md:text-5xl lg:text-6xl font-bold mb-4 md:mb-6 text-primary tracking-tight leading-tight md:leading-none">Где вы теряете деньги <br class="hidden md:inline" />прямо сейчас?</h2>
    </div>

    <!-- Bento Grid with dynamic auto-expanding rows, optimized for compact styling -->
    <div class="flex overflow-x-auto snap-x snap-mandatory pb-8 -mx-6 px-6 md:mx-0 md:px-0 md:grid md:grid-cols-3 md:overflow-visible gap-4 md:gap-6 no-scrollbar">
      
      <!-- Card 1 (Socials) -->
      <div class="md:col-span-2 group relative overflow-hidden rounded-3xl md:rounded-[2.5rem] bg-gradient-to-br from-primary to-[#1E2B38] text-background border border-white/10 hover:border-accent/40 hover:-translate-y-1 transition-all duration-500 ease-out p-6 md:p-8 flex flex-col justify-between shadow-xl min-w-[85vw] snap-center md:min-w-0 md:min-h-[280px] reveal">
        <!-- Ambient inner glow for a premium look -->
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-accent/10 rounded-full blur-3xl pointer-events-none group-hover:bg-accent/20 transition-all duration-700" style="will-change: transform, opacity; transform: translateZ(0);"></div>
        
        <!-- Top Part: Title, Icon & Description grouped together -->
        <div class="relative z-10">
          <!-- Top Row: Title & Icon side-by-side -->
          <div class="flex justify-between items-start gap-4 mb-4">
            <h3 class="text-2xl md:text-3xl font-extrabold tracking-tight text-white leading-tight">Социальные сети не приносят новых клиентов</h3>
            <div class="w-12 h-12 rounded-xl bg-[#F3EFE6] text-accent flex items-center justify-center shadow-lg shadow-black/10 shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"></path></svg>
            </div>
          </div>
          <!-- Description -->
          <p class="text-background/70 text-sm md:text-base leading-relaxed max-w-xl font-medium">
            Вы вкладываете ресурсы в ведение профиля, но получаете только просмотры. Нет выстроенной воронки, которая превращает молчаливого зрителя в реального покупателя.
          </p>
        </div>
        <!-- Bottom Part: Button pushed to the bottom -->
        <div class="flex justify-start md:justify-end mt-6 relative z-10">
          <button onclick="openMobilePainModal(0)" class="w-[150px] inline-flex items-center justify-center gap-2 text-white font-semibold bg-white/[0.06] hover:bg-accent hover:text-white border border-white/10 hover:border-accent py-2.5 rounded-xl transition-all duration-300 hover:shadow-[0_0_20px_rgba(107,29,47,0.4)] group/btn shrink-0 leading-none text-base">
            Подробнее 
            <svg class="w-4 h-4 transform group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
          </button>
        </div>
      </div>

      <!-- Card 2 (Maps) -->
      <div class="group relative overflow-hidden rounded-3xl md:rounded-[2.5rem] bg-gradient-to-br from-primary to-[#1E2B38] text-background border border-white/10 hover:border-accent/40 hover:-translate-y-1 transition-all duration-500 ease-out p-6 md:p-8 flex flex-col justify-between shadow-xl min-w-[85vw] snap-center md:min-w-0 md:min-h-[280px] reveal">
        <!-- Ambient inner glow for a premium look -->
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-accent/10 rounded-full blur-3xl pointer-events-none group-hover:bg-accent/20 transition-all duration-700" style="will-change: transform, opacity; transform: translateZ(0);"></div>

        <!-- Top Part -->
        <div class="relative z-10">
          <!-- Top Row: Title & Icon side-by-side to save vertical space -->
          <div class="flex justify-between items-start gap-4 mb-4">
            <h3 class="text-xl md:text-2xl font-extrabold tracking-tight text-white leading-tight">Потеря трафика с геосервисов</h3>
            <div class="w-12 h-12 rounded-xl bg-[#F3EFE6] text-accent flex items-center justify-center shadow-lg shadow-black/10 shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            </div>
          </div>
          <p class="text-background/70 leading-relaxed text-sm md:text-base font-medium">
            Карты Яндекс, Google и 2ГИС — источник самого горячего трафика. Клиенты уже ищут услугу рядом и готовы покупать. Если карточка не оптимизирована, все заказы уйдут вашим конкурентам.
          </p>
        </div>
        <div class="flex justify-start relative z-10 mt-6">
          <button onclick="openMobilePainModal(1)" class="w-[150px] inline-flex items-center justify-center gap-2 text-white font-semibold bg-white/[0.06] hover:bg-accent hover:text-white border border-white/10 hover:border-accent py-2.5 rounded-xl transition-all duration-300 hover:shadow-[0_0_20px_rgba(107,29,47,0.4)] group/btn shrink-0 leading-none text-base">
            Подробнее 
            <svg class="w-4 h-4 transform group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
          </button>
        </div>
      </div>

      <!-- Card 3 (Routine) -->
      <div class="group relative overflow-hidden rounded-3xl md:rounded-[2.5rem] bg-gradient-to-br from-primary to-[#1E2B38] text-background border border-white/10 hover:border-accent/40 hover:-translate-y-1 transition-all duration-500 ease-out p-6 md:p-8 flex flex-col justify-between shadow-xl min-w-[85vw] snap-center md:min-w-0 md:min-h-[280px] reveal">
        <!-- Ambient inner glow for a premium look -->
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-accent/10 rounded-full blur-3xl pointer-events-none group-hover:bg-accent/20 transition-all duration-700" style="will-change: transform, opacity; transform: translateZ(0);"></div>

        <!-- Mobile Layout -->
        <div class="md:hidden flex flex-col h-full justify-between">
          <div class="relative z-10">
            <div class="flex justify-between items-start gap-4 mb-4">
              <h3 class="text-xl font-extrabold tracking-tight text-white leading-tight">Потеря времени на процессах</h3>
              <div class="w-12 h-12 rounded-xl bg-[#F3EFE6] text-accent flex items-center justify-center shadow-lg shadow-black/10 shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              </div>
            </div>
            <p class="text-background/70 leading-relaxed text-sm font-medium mb-6">
              Отсутствие автоматизации заставляет вас и ваших сотрудников делать работу вручную. Рутина съедает время, снижает скорость ответов и приводит к потере лояльности.
            </p>
          </div>
          <div class="flex justify-start relative z-10 mt-auto">
            <button onclick="openMobilePainModal(2)" class="w-[150px] inline-flex items-center justify-center gap-2 text-white font-semibold bg-white/[0.06] hover:bg-accent hover:text-white border border-white/10 hover:border-accent py-2.5 rounded-xl transition-all duration-300 hover:shadow-[0_0_20px_rgba(107,29,47,0.4)] group/btn shrink-0 leading-none text-base">
              Подробнее 
              <svg class="w-4 h-4 transform group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </button>
          </div>
        </div>

        <!-- Desktop Layout -->
        <div class="hidden md:flex flex-row items-center w-full relative z-10">
          <!-- Left Content: Icon + Text -->
          <div class="w-[calc(66.667%+3.667rem)] flex flex-row items-center gap-6 shrink-0">
            <!-- Icon -->
            <div class="w-12 h-12 rounded-xl bg-[#F3EFE6] text-accent flex items-center justify-center shadow-lg shadow-black/10 shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <!-- Text -->
            <div class="flex-1">
              <h3 class="text-2xl font-extrabold mb-2 tracking-tight text-white">Потеря времени на процессах</h3>
              <p class="text-background/70 leading-relaxed text-base max-w-2xl font-medium">
                Отсутствие автоматизации заставляет вас и ваших сотрудников делать работу вручную. Рутина съедает время, снижает скорость ответов и приводит к потере лояльности.
              </p>
            </div>
          </div>
          <!-- Button -->
          <div class="flex-1 flex justify-start">
            <button onclick="openMobilePainModal(2)" class="w-[150px] inline-flex items-center justify-center gap-2 text-white font-semibold bg-white/[0.06] hover:bg-accent hover:text-white border border-white/10 hover:border-accent py-2.5 rounded-xl transition-all duration-300 hover:shadow-[0_0_20px_rgba(107,29,47,0.4)] group/btn shrink-0 leading-none text-base">
              Подробнее 
              <svg class="w-4 h-4 transform group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Interactive Modal for PainPoints (Outside the below-fold wrapper to avoid clipping) -->
<div id="pain-popup-overlay-mobile" class="fixed inset-0 bg-primary/40 backdrop-blur-md z-[999] opacity-0 pointer-events-none transition-all duration-500 flex items-end justify-center">
  <div id="pain-popup-card-mobile" class="bg-background w-full rounded-t-[2rem] p-6 border-t border-primary/10 shadow-[0_-10px_40px_rgba(26,37,48,0.15)] transform translate-y-full opacity-0 transition-all duration-500 relative flex flex-col max-h-[85dvh] overflow-y-auto">
    
    <button onclick="closeMobilePainModal()" class="absolute top-4 right-4 w-10 h-10 bg-white hover:bg-primary/5 rounded-full flex items-center justify-center text-primary border border-primary/5 shadow-sm cursor-pointer z-20" aria-label="Закрыть">
      <svg class="w-5 h-5 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>
    
    <div class="relative z-10 mt-4 flex flex-col">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent/10 mb-4 self-start">
        <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
        <span class="text-xs font-bold text-accent uppercase tracking-wider">Анализ проблемы</span>
      </div>
      <h3 id="pain-popup-title-mobile" class="text-2xl font-black text-primary tracking-tight mb-5 leading-tight"></h3>
      
      <div class="space-y-4">
        <div class="bg-white rounded-2xl p-5 border border-primary/5">
          <h4 class="text-sm font-extrabold text-primary/40 uppercase tracking-wider mb-2">Суть проблемы:</h4>
          <p id="pain-popup-desc-mobile" class="text-primary/90 text-sm leading-relaxed font-medium"></p>
        </div>
        
        <div class="bg-accent/5 rounded-2xl p-5 border border-accent/10">
          <h4 class="text-sm font-extrabold text-accent/70 uppercase tracking-wider mb-2">Сколько это стоит вашему бизнесу:</h4>
          <p id="pain-popup-cost-mobile" class="text-primary/90 text-sm leading-relaxed font-semibold"></p>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(() => {

  const painData = [
    {
      title: "Социальные сети не приносят новых клиентов",
      desc: "Вы тратите время и деньги на создание контента, оформление постов и сторис, но вместо входящих заявок видите только пустые охваты и лайки. Без грамотно выстроенной лид-магнитной воронки и автоматического прогрева потенциальные клиенты так и остаются просто зрителями.",
      cost: "Упущенная прибыль с каждого подписчика, который зашёл, но не сконвертировался. Рекламный бюджет тратится впустую, а стоимость привлечения одного реального покупателя возрастает в несколько раз."
    },
    {
      title: "Потеря трафика с геосервисов",
      desc: "Карты Яндекс, Google и 2ГИС — источник самого горячего поискового трафика. Клиенты уже ищут услугу рядом с собой и готовы покупать. Если карточка не оптимизирована, она опускается ниже 5-й позиции, и все заказы уходят вашим конкурентам.",
      cost: "Вы теряете от 30% до 60% локальных клиентов, которые могли бы прийти абсолютно бесплатно. Конкуренты в топ-3 получают поток заявок без затрат на рекламу, пока вы переплачиваете за платные лиды."
    },
    {
      title: "Потеря времени на процессах",
      desc: "Ваши менеджеры вручную отправляют реквизиты, подтверждают записи, часами отвечают на типовые вопросы в чатах и забывают перезвонить. Из-за рутины скорость обработки заявок падает, клиенты уходят к тем, кто отвечает моментально, а сотрудники перегружены.",
      cost: "Низкая конверсия из заявки в продажу из-за долгого ответа. Дополнительные расходы на раздутый штат сотрудников, выполняющих механическую работу, которую можно автоматизировать за 1 день с помощью чат-ботов."
    }
  ];

  const pOverlay = document.getElementById('pain-popup-overlay-mobile');
  const pCard = document.getElementById('pain-popup-card-mobile');
  
  window.openMobilePainModal = function(index) {
    const data = painData[index];
    document.getElementById('pain-popup-title-mobile').innerText = data.title;
    document.getElementById('pain-popup-desc-mobile').innerText = data.desc;
    document.getElementById('pain-popup-cost-mobile').innerText = data.cost;
    
    pOverlay.classList.remove('opacity-0', 'pointer-events-none');
    pCard.classList.remove('translate-y-full', 'opacity-0');
    pCard.classList.add('translate-y-0', 'opacity-100');
    document.body.style.overflow = 'hidden';
  };

  window.closeMobilePainModal = function() {
    pOverlay.classList.add('opacity-0', 'pointer-events-none');
    pCard.classList.remove('translate-y-0', 'opacity-100');
    pCard.classList.add('translate-y-full', 'opacity-0');
    document.body.style.overflow = '';
  };

  pOverlay.addEventListener('click', (e) => {
    if (e.target === pOverlay) window.closeMobilePainModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !pOverlay.classList.contains('opacity-0')) {
      window.closeMobilePainModal();
    }
  });

})();
</script>
