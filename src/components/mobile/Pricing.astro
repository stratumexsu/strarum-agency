---
import Button from '../ui/Button.astro';

const categories = [
  {
    title: "Комплексные решения",
    badge: "Лучший выбор",
    items: [
      { name: "Полная оптимизация бизнеса", desc: "SMM + SEO + внедрение ботов", price: "от 15 000 ₽" },
      { name: "Комплексное ведение Instagram", desc: "Контент матрица + сценарии Reels + написание постов + бот", price: "11 000 ₽" }
    ]
  },
  {
    title: "SMM",
    items: [
      { name: "Составление контент-матрицы", desc: "Вовлечение + прогрев + удержание", price: "2 500 ₽" },
      { name: "Написание Reels сценариев", desc: "Пакет от 10 сценариев", price: "3 500 ₽" },
      { name: "Написание постов", desc: "Комплексно, пакетом 10 шт.", price: "2 000 ₽" }
    ]
  },
  {
    title: "Сайты и чат боты",
    badge: "Новинка",
    items: [
      { 
        name: "Разработка Landing Page", 
        desc: "Индивидуальный дизайн, адаптивная верстка, интеграция форм и базовое SEO", 
        price: "от 10 000 ₽", 
        isNew: true 
      },
      { name: "Бот для Instagram", desc: "С лид-магнитом", price: "3 500 ₽ *" },
      { name: "Бот для Telegram", desc: "С CRM системой", price: "4 000 ₽ **" }
    ],
    disclaimer: [
      "* 1 500 ₽ написание логики работы бота + 2 000 ₽/мес подписка. Бесплатное изменение контента в рамках срока КП. Вне срока — от 1 000 ₽.",
      "** 3 000 ₽ написание логики работы бота + ежемесячная подписка на сервис. В первый месяц правки бесплатные. Далее — 500 ₽/правка."
    ]
  },
  {
    title: "SEO",
    items: [
      { name: "Выделение семантического ядра", desc: "Для сайта и карт", price: "500 ₽" },
      { name: "Локальная SEO оптимизация", desc: "Яндекс.Карты + 2ГИС", price: "2 500 ₽" },
      { name: "SEO оптимизация сайта", desc: "Глубокий технический и внутренний аудит", price: "Уточняйте у менеджера" }
    ]
  },
  {
    title: "Точечные услуги",
    items: [
      { name: "Аудит компании", desc: "SEO, SMM и консалтинг", price: "1 000 ₽" },
      { name: "Анализ целевой аудитории", desc: "Глубинный анализ клиентов с выявлением инсайтов и страхов", price: "1 000 ₽" }
    ]
  }
];
---

<div class="below-fold px-6 py-10 bg-[#F5F2EB] text-primary relative flex flex-col justify-center overflow-hidden">
  <!-- Decorative background glows -->
  <div class="absolute top-1/3 left-1/4 w-[500px] h-[500px] bg-primary/3 rounded-full blur-[100px] pointer-events-none -z-10" style="will-change: transform; transform: translateZ(0);"></div>
  <div class="absolute bottom-10 right-1/4 w-[400px] h-[400px] bg-accent/3 rounded-full blur-[80px] pointer-events-none -z-10" style="will-change: transform; transform: translateZ(0);"></div>

  <div class="max-w-xl mx-auto w-full relative z-10 flex flex-col">
    
    <!-- Centered Header -->
    <div class="text-center mb-6 reveal">
      <div class="flex justify-center mb-4">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/5 border border-primary/10 select-none cursor-default">
          <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
          <span class="text-[11px] font-bold text-primary/70 uppercase tracking-wider">Прайс-лист</span>
        </div>
      </div>
      <h2 class="text-2xl sm:text-3xl font-extrabold text-primary mb-2 tracking-tight">Стоимость наших услуг</h2>
      <p class="text-sm text-primary/60 font-medium">Выберите интересующее вас направление</p>
    </div>

    <!-- Accordion Category Stack -->
    <div class="space-y-3.5 w-full mt-2 reveal">
      {categories.map((cat, idx) => (
        <div 
          class={`pricing-accordion-item group w-full border rounded-3xl transition-all duration-500 overflow-hidden shadow-md ${
            idx === 0 
              ? 'bg-primary text-white border-white/5' 
              : 'bg-white/80 backdrop-blur-md text-primary border-primary/5 [&.active]:bg-white [&.active]:text-primary [&.active]:border-accent/20'
          }`}
          data-index={idx}
        >
          {/* Header trigger button */}
          <button class="pricing-accordion-trigger w-full flex items-center justify-between p-5 text-left cursor-pointer focus:outline-none select-none active:scale-[0.99] transition-transform">
            <div class="flex items-center gap-3">
              <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
              <span class={`text-sm font-extrabold tracking-tight uppercase transition-colors ${idx === 0 ? 'text-white' : 'text-primary'}`}>{cat.title}</span>
            </div>
            <div class="flex items-center gap-2">
              {cat.badge && (
                <span class={`px-2.5 py-0.5 rounded-full text-[9px] font-extrabold uppercase tracking-wider border transition-all duration-300 ${
                  idx === 0 
                    ? 'bg-accent text-white border-transparent' 
                    : 'bg-accent/10 text-accent border-accent/20'
                }`}>
                  {cat.badge}
                </span>
              )}
              <div class={`pricing-accordion-icon w-6 h-6 rounded-full flex items-center justify-center shrink-0 transition-all duration-300 ${idx === 0 ? 'bg-white/10 text-white' : 'bg-primary/5 text-primary/80'}`}>
                <svg class={`w-3.5 h-3.5 ${idx === 0 ? 'text-white' : 'text-primary/80'}`} fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
                </svg>
              </div>
            </div>
          </button>

          {/* Panel content */}
          <div class="pricing-accordion-content transition-all duration-500 ease-in-out max-h-0 opacity-0 overflow-hidden">
            <div class="px-5 pb-5 pt-0">
              <div class={`divider-line w-full h-px mb-2 ${idx === 0 ? 'bg-white/10' : 'bg-primary/10'}`}></div>
              
              <div class="divide-y divide-primary/5">
                {cat.items.map((item) => (
                  <div class={item.isNew 
                    ? "relative p-3 my-2 rounded-2xl border border-accent/35 bg-accent/[0.02] shadow-[0_4px_15px_rgba(107,29,47,0.02)] flex flex-col gap-1"
                    : "py-3.5 flex flex-col gap-1"
                  }>
                    {item.isNew && (
                      <span class="absolute -top-1.5 right-4 px-2 py-0.5 rounded bg-accent text-white text-[8px] font-black uppercase tracking-wider shadow-sm select-none pointer-events-none z-10">
                        Новинка
                      </span>
                    )}
                    <div class="flex justify-between items-center gap-2">
                      <h4 class={`text-sm font-bold leading-snug transition-colors ${idx === 0 ? 'text-white' : 'text-primary'}`}>
                        {item.name}
                      </h4>
                      <span class={`price-val text-sm font-extrabold shrink-0 leading-none whitespace-nowrap transition-colors ${idx === 0 ? 'text-white' : 'text-accent'}`}>
                        {item.price}
                      </span>
                    </div>
                    <p class={`text-xs font-medium leading-relaxed transition-colors ${idx === 0 ? 'text-white/70' : 'text-primary/60'}`}>
                      {item.desc}
                    </p>
                  </div>
                ))}
              </div>

              {cat.disclaimer && (
                <div class={`disclaimer-box mt-4 p-4 rounded-2xl text-[11px] font-medium space-y-2 border transition-all duration-300 ${idx === 0 ? 'bg-white/5 text-white/90 border-white/10' : 'bg-primary/[0.03] text-primary/80 border-primary/5'}`}>
                  {cat.disclaimer.map((disc) => (
                    <p class="leading-relaxed">{disc}</p>
                  ))}
                </div>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA Button -->
    <div class="flex justify-center mt-8 reveal">
      <Button id="pricing-cta-mobile" variant="primary" href="#consultation" class="px-6 py-4 text-sm font-extrabold tracking-wider uppercase inline-flex items-center gap-2 shadow-lg shadow-accent/20 w-auto justify-center text-center">
        Получить предложение
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
        </svg>
      </Button>
    </div>

  </div>

  <script is:inline>
    (() => {
      document.addEventListener('DOMContentLoaded', () => {
        const items = document.querySelectorAll('.pricing-accordion-item');
        const ctaButton = document.getElementById('pricing-cta-mobile');

        function updateCTA(categoryName) {
          if (!ctaButton) return;
          const form = document.querySelector('#consultation form');
          if (form) {
            let serviceInput = form.querySelector('input[name="interested_service"]');
            if (!serviceInput) {
              serviceInput = document.createElement('input');
              serviceInput.type = 'hidden';
              serviceInput.name = 'interested_service';
              form.appendChild(serviceInput);
            }
            serviceInput.value = categoryName;
          }
        }

        function toggleAccordion(index) {
          const targetItem = items[index];
          const isAlreadyActive = targetItem.classList.contains('active');

          items.forEach((item, idx) => {
            const content = item.querySelector('.pricing-accordion-content');
            const icon = item.querySelector('.pricing-accordion-icon');
            if (idx === index && !isAlreadyActive) {
              item.classList.add('active', 'shadow-xl');
              if (idx !== 0) item.classList.remove('shadow-md');
              content.style.maxHeight = content.scrollHeight + 'px';
              content.style.opacity = '1';
              if (icon) icon.style.transform = 'rotate(180deg)';
            } else {
              item.classList.remove('active', 'shadow-xl');
              if (idx !== 0) item.classList.add('shadow-md');
              content.style.maxHeight = '0px';
              content.style.opacity = '0';
              if (icon) icon.style.transform = 'rotate(0deg)';
            }
          });
        }

        // Initialize first item as active by default, but allow toggling it closed
        items[0].classList.add('active', 'shadow-xl');
        const firstContent = items[0].querySelector('.pricing-accordion-content');
        const firstIcon = items[0].querySelector('.pricing-accordion-icon');
        firstContent.style.maxHeight = firstContent.scrollHeight + 'px';
        firstContent.style.opacity = '1';
        if (firstIcon) firstIcon.style.transform = 'rotate(180deg)';

        updateCTA("Комплексные решения");

        items.forEach((item, index) => {
          const trigger = item.querySelector('.pricing-accordion-trigger');
          if (trigger) {
            trigger.addEventListener('click', () => {
              toggleAccordion(index);
              const titleEl = trigger.querySelector('span:not(.bg-accent)');
              if (titleEl) {
                updateCTA(titleEl.textContent.trim());
              }
            });
          }
        });
      });
    })();
  </script>
</div>
