---
import Button from '../ui/Button.astro';

const navItems = [
  { label: 'Главная', href: '#' },
  { label: 'Боли', href: '#pain-points' },
  { label: 'Услуги', href: '#services' },
  { label: 'Этапы', href: '#stages' },
  { label: 'Кейсы', href: '#cases' },
  { label: 'Прайс', href: '#pricing' },
  { label: 'FAQ', href: '#faq' }
];
---

<header class="fixed top-0 left-0 w-full z-50 bg-[#F5F2EB] backdrop-blur-md border-b border-primary/5">
  <div class="px-6 h-20 flex items-center justify-between">
    <!-- Логотип и Название -->
    <a href="#" class="flex items-center gap-0 group">
      <img src="/logo.png" alt="Stratum Agency Logo" class="w-12 h-12 object-contain mix-blend-multiply -mr-1.5 shrink-0" decoding="async" />
      <span class="text-xl font-black text-primary tracking-tight">Stratum<span class="text-accent">Agency</span></span>
    </a>
    
    <button id="mobile-menu-btn" class="text-primary p-2 -mr-2 outline-none focus:outline-none">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path></svg>
    </button>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu-overlay" class="fixed inset-0 bg-[#F5F2EB] z-[100] transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col">
  <!-- Overlay Header -->
  <div class="h-20 px-6 flex items-center justify-between shrink-0 border-b border-primary/5">
    <div class="flex items-center gap-0">
      <span class="text-xl font-black text-primary tracking-tight">Stratum<span class="text-accent">Agency</span></span>
    </div>
    <button id="mobile-menu-close" class="text-primary p-2 -mr-2 outline-none focus:outline-none">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>
  </div>

  <!-- Content -->
  <div class="flex-1 overflow-y-auto px-8 pt-8 pb-10 flex flex-col">
    <!-- Навигация -->
    <div class="mobile-menu-content opacity-0 translate-y-4 transition-all duration-300 ease-out" style="transition-delay: 100ms;">
      <h4 class="text-primary/40 text-[11px] font-bold uppercase tracking-[0.2em] mb-6">Навигация</h4>
      <nav class="flex flex-col gap-5">
        {navItems.map((item) => (
          <a href={item.href} class="mobile-nav-link text-2xl font-semibold text-primary active:text-accent transition-colors">{item.label}</a>
        ))}
      </nav>
    </div>

    <!-- Divider -->
    <div class="w-full h-px bg-primary/10 my-8 mobile-menu-content opacity-0 transition-all duration-300" style="transition-delay: 200ms;"></div>

    <!-- Контакты -->
    <div class="mobile-menu-content opacity-0 translate-y-4 transition-all duration-300 ease-out" style="transition-delay: 300ms;">
      <h4 class="text-primary/40 text-[11px] font-bold uppercase tracking-[0.2em] mb-6">Контакты</h4>
      <div class="flex flex-col gap-5">
        <a href="mailto:hello@stratumagency.ru" class="mobile-nav-link flex items-center gap-3 text-lg font-medium text-primary/80 active:text-accent transition-colors">
          <svg class="w-6 h-6 text-primary/60" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          hello@stratumagency.ru
        </a>
        <a href="https://t.me/stratum_agency" target="_blank" class="mobile-nav-link flex items-center gap-3 text-lg font-medium text-primary/80 active:text-accent transition-colors">
          <svg class="w-6 h-6 text-primary/60" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69a.2.2 0 00-.05-.18c-.06-.05-.14-.03-.21-.02-.09.02-1.49.95-4.22 2.79-.4.27-.76.41-1.08.4-.36-.01-1.04-.2-1.55-.37-.63-.2-1.12-.31-1.08-.66.02-.18.27-.36.74-.55 2.92-1.27 4.86-2.11 5.83-2.51 2.78-1.16 3.35-1.36 3.73-1.36.08 0 .27.02.39.12.1.08.13.19.14.27-.01.06.01.24 0 .38z"/></svg>
          Telegram
        </a>
        <a href="https://www.instagram.com/stratumagencyy/" target="_blank" class="mobile-nav-link flex items-center gap-3 text-lg font-medium text-primary/80 active:text-accent transition-colors">
          <svg class="w-6 h-6 text-primary/60 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051C.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          Instagram
        </a>
      </div>
    </div>
    
    <!-- CTA Button -->
    <div class="mt-auto pt-10 w-full shrink-0 mobile-menu-content opacity-0 translate-y-4 transition-all duration-300 ease-out" style="transition-delay: 400ms;">
      <Button id="mobile-nav-consult-btn" variant="primary" href="#consultation" class="w-full justify-center py-4 text-lg shadow-xl shadow-accent/20 rounded-2xl">
        Обсудить проект
      </Button>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const menuBtn = document.getElementById('mobile-menu-btn');
    const closeBtn = document.getElementById('mobile-menu-close');
    const overlay = document.getElementById('mobile-menu-overlay');
    const navLinks = document.querySelectorAll('.mobile-nav-link');
    const consultBtn = document.getElementById('mobile-nav-consult-btn');
    const contents = document.querySelectorAll('.mobile-menu-content');

    let isOpen = false;

    function openMenu() {
      isOpen = true;
      document.body.style.overflow = 'hidden';
      overlay.classList.remove('translate-x-full');
      overlay.classList.add('translate-x-0');
      
      setTimeout(() => {
        contents.forEach(el => {
          el.classList.remove('opacity-0', 'translate-y-4');
        });
      }, 50);
    }

    function closeMenu() {
      isOpen = false;
      document.body.style.overflow = '';
      overlay.classList.remove('translate-x-0');
      overlay.classList.add('translate-x-full');
      
      contents.forEach(el => {
        el.classList.add('opacity-0', 'translate-y-4');
      });
    }

    if (menuBtn) menuBtn.addEventListener('click', openMenu);
    if (closeBtn) closeBtn.addEventListener('click', closeMenu);
    function smoothScrollToCenter(targetId) {
      if (targetId === '#' || targetId === '') {
        window.scrollTo({ top: 0, behavior: 'smooth' });
        return;
      }
      const targetEl = document.querySelector(targetId);
      if (targetEl) {
        // Wait for the slide-out menu closing animation to complete (300ms)
        setTimeout(() => {
          targetEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }, 300);
      }
    }

    navLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        const href = link.getAttribute('href');
        if (href && href.startsWith('#')) {
          e.preventDefault();
          closeMenu();
          smoothScrollToCenter(href);
        } else {
          closeMenu();
        }
      });
    });

    if (consultBtn) {
      consultBtn.addEventListener('click', (e) => {
        const href = consultBtn.getAttribute('href');
        if (href && href.startsWith('#')) {
          e.preventDefault();
          closeMenu();
          smoothScrollToCenter(href);
        } else {
          closeMenu();
        }
      });
    }
  })();
</script>
