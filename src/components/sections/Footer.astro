---
const navItems = [
  { label: 'Главная', href: '#' },
  { label: 'Боли', href: '#pain-points' },
  { label: 'Услуги', href: '#services' },
  { label: 'Этапы', href: '#stages' },
  { label: 'Кейсы', href: '#cases' },
  { label: 'Прайс', href: '#pricing' },
  { label: 'FAQ', href: '#faq' }
];
---

<footer class="below-fold bg-[#111922] text-white/80 pt-16 relative overflow-hidden">
  <!-- Subtle ambient glow in the footer -->
  <div class="absolute -bottom-48 -right-48 w-96 h-96 bg-accent/5 rounded-full blur-[100px] pointer-events-none"></div>
  <div class="absolute -top-48 -left-48 w-96 h-96 bg-primary/10 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 pb-16 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-start">
      
      <!-- Column 1 & 2: Brand, Navigation (2 cols) & Company (lg:col-span-8) -->
      <div class="lg:col-span-8 flex flex-col items-start text-left">
        <!-- Big Brand Name -->
        <span class="text-3xl md:text-[40px] font-black text-white tracking-tight leading-none mb-8 block select-none">
          Stratum<span class="text-accent">Agency</span>
        </span>
        
        <div class="flex flex-col sm:flex-row gap-12 sm:gap-16 w-full">
          <!-- Navigation (Two Columns, Closer) -->
          <div class="shrink-0">
            <h4 class="text-white font-extrabold text-base md:text-lg uppercase tracking-[0.15em] mb-6">Навигация</h4>
            <ul class="grid grid-cols-2 gap-x-4 gap-y-3 max-w-[240px]">
              {navItems.map(item => (
                <li>
                  <a href={item.href} class="text-base text-white/70 hover:text-accent font-semibold transition-colors duration-300 py-1 block">
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Company Documents (Moved Closer) -->
          <div class="shrink-0">
            <h4 class="text-white font-extrabold text-base md:text-lg uppercase tracking-[0.15em] mb-6">Компания</h4>
            <ul class="space-y-4">
              <li>
                <a href="/docs/privacy.pdf" target="_blank" class="text-base text-white/70 hover:text-accent font-semibold transition-colors duration-300 leading-tight block">
                  Политика<br/>конфиденциальности
                </a>
              </li>
              <li>
                <a href="/docs/personal-data.pdf" target="_blank" class="text-base text-white/70 hover:text-accent font-semibold transition-colors duration-300 leading-tight block">
                  Защита персональных<br/>данных
                </a>
              </li>
              <li>
                <a href="/docs/marketing-consent.pdf" target="_blank" class="text-base text-white/70 hover:text-accent font-semibold transition-colors duration-300 leading-tight block">
                  Согласие на<br/>рекламную рассылку
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Column 3: Contact details & Socials (lg:col-span-4) -->
      <div class="lg:col-span-4 flex flex-col items-start lg:items-end text-left lg:text-right w-full lg:self-center">
        <h4 class="text-white font-extrabold text-2xl md:text-3xl uppercase tracking-wider mb-6">Контакты</h4>
        
        <div class="flex flex-col items-start lg:items-end gap-6 w-full">
          <!-- Email Link -->
          <a href="mailto:hello@stratumagency.ru" class="text-lg md:text-xl font-bold text-white hover:text-accent transition-colors block">
            hello@stratumagency.ru
          </a>

          <!-- Social Media Icons (TG, VK, INST) -->
          <div class="flex items-center gap-3">
            <!-- Telegram -->
            <a href="https://t.me/stratum_agency" target="_blank" aria-label="Telegram" class="w-10 h-10 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-white/80 hover:text-white hover:bg-accent hover:border-accent hover:-translate-y-1 transition-all duration-300">
              <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69.01-.03.01-.14-.07-.2-.08-.06-.19-.04-.27-.02-.11.02-1.93 1.23-5.46 3.62-.51.35-.98.53-1.39.52-.46-.01-1.33-.26-1.98-.48-.8-.27-1.43-.42-1.37-.89.03-.25.38-.51 1.03-.78 4.04-1.76 6.74-2.92 8.1-3.48 3.85-1.6 4.64-1.88 5.17-1.89.11 0 .37.03.54.17.14.12.18.28.2.45-.02.07-.02.13-.02.19z"/>
              </svg>
            </a>
            <!-- VK -->
            <a href="https://vk.com/stratumagency" target="_blank" aria-label="VK" class="w-10 h-10 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-white/80 hover:text-white hover:bg-accent hover:border-accent hover:-translate-y-1 transition-all duration-300">
              <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
                <path d="M15.06 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 15.06 2zm2.93 12.3c-.09.21-.49.52-.94.52s-.75-.24-1.22-.61c-.57-.45-1.05-.59-1.37-.4-.36.21-.57.73-.57 1.28v.09c0 .73-.39 1.12-1.09 1.12-.96 0-2.31-.69-3.41-1.89C8.36 13.3 7.5 11.75 7.5 10.3c0-.46.33-.78.8-.78s.77.24 1 .63c.48.81.98 1.58 1.4 1.77.29.13.43 0 .43-.37V10.2c0-.52-.3-.79-.81-.79-.11 0-.25.02-.38.05.21-.49.69-.8 1.26-.8.74 0 1.09.43 1.09 1.12v1.54c0 .35.12.46.31.46s.39-.12.63-.44c.64-.84 1.15-1.92 1.34-2.45.1-.28.37-.47.67-.47h.81c.47 0 .69.29.56.71-.19.64-1.07 2.1-1.36 2.52-.24.34-.23.49.03.78.36.41.97 1.01 1.31 1.48.24.32.22.61-.13.72z"/>
              </svg>
            </a>
            <!-- Instagram -->
            <a href="https://www.instagram.com/stratumagencyy/" target="_blank" aria-label="Instagram" class="w-10 h-10 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-white/80 hover:text-white hover:bg-accent hover:border-accent hover:-translate-y-1 transition-all duration-300">
              <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051C.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Full screen divider line and centered copyright -->
  <div class="w-full border-t border-white/5 py-8 text-center text-xs text-white/40 relative z-10">
    &copy; {new Date().getFullYear()} STRATUM AGENCY. Все права защищены.
  </div>
</footer>
