        result: "14",
        resultSuffix: " часов посадки",
        chartType: "line",
        val1: "",
        val2: "Стабильный поток клиентов",
        labels: ["8:00", "12:00", "16:00", "19:00", "23:00"],
        sub: "График посадки с системой Stratum",
        points: [
          { x: 0, y: 38 },
          { x: 25, y: 28 },
          { x: 50, y: 34 },
          { x: 75, y: 25 },
          { x: 100, y: 38 }
        ],
        path: "M 0,38 L 25,28 L 50,34 L 75,25 L 100,38",
        area: "M 0,38 L 25,28 L 50,34 L 75,25 L 100,38 L 100,100 L 0,100 Z",
        val2Left: "50%",
        val2Bottom: "92%",
        val2Transform: "translateX(-50%)"
      }
    ];

    const cOverlay = document.getElementById('case-popup-overlay');
    const cCard = document.getElementById('case-popup-card');
    let counterAnimationFrame;
    let pieAnimationFrame;
    
    window.openCaseModal = function(index) {
      const data = caseData[index];
      const type = data.chartType;
      
      document.getElementById('case-popup-title').innerText = data.title;
      document.getElementById('case-popup-tag').innerText = data.tag;
      document.getElementById('case-popup-prob').innerText = data.prob;
      document.getElementById('case-popup-sol').innerText = data.sol;
      
      const resEl = document.getElementById('case-popup-result');
      resEl.innerText = "0" + (data.resultSuffix || "");
      
      document.getElementById('chart-bar-container').classList.add('hidden');
      document.getElementById('chart-line-container').classList.add('hidden');
      document.getElementById('chart-pie-container').classList.add('hidden');
      
      if (type === 'line') {
        document.getElementById('chart-line-container').classList.remove('hidden');
        
        const val1 = document.getElementById('case-line-val-1');
        if (data.val1) {
          val1.innerText = data.val1;
          val1.style.display = '';
        } else {
          val1.style.display = 'none';
        }
        
        const val2 = document.getElementById('case-line-val-2');
        if (data.val2) {
          val2.innerText = data.val2;
          val2.style.display = '';
        } else {
          val2.style.display = 'none';
        }
        
        const labelsContainer = document.getElementById('case-line-labels-container');
        labelsContainer.innerHTML = '';
        if (data.labels) {
          data.labels.forEach((lbl, idx) => {
            const el = document.createElement('div');
            if (idx === data.labels.length - 1 && data.title !== 'Specialty кофейня') {
              el.className = 'text-right text-accent font-bold';
            } else if (idx === 0) {
              el.className = 'text-left';
            } else if (idx === data.labels.length - 1) {
              el.className = 'text-right';
            } else {
              el.className = 'text-center';
            }
            el.innerText = lbl;
            labelsContainer.appendChild(el);
          });
        }
        
        const subEl = document.getElementById('case-line-sub');
        if (data.sub) {
          subEl.innerText = data.sub;
          subEl.classList.remove('hidden');
        } else {
          subEl.classList.add('hidden');
        }
        
        const path = document.getElementById('case-line-path');
        const area = document.getElementById('case-line-area');
        path.setAttribute('d', data.path);
        area.setAttribute('d', data.area);
        
        if (data.val1Left) {
          val1.style.left = data.val1Left;
          val1.style.right = 'auto';
        } else {
          val1.style.left = '0';
          val1.style.right = 'auto';
        }
        val1.style.bottom = data.val1Bottom || "4px";
        val1.style.transform = data.val1Transform || "translateX(0%)";
        
        if (data.val2Left) {
          val2.style.left = data.val2Left;
          val2.style.right = 'auto';
        } else if (data.val2Right) {
          val2.style.right = data.val2Right;
          val2.style.left = 'auto';
        } else {
          val2.style.right = '0';
          val2.style.left = 'auto';
        }
        val2.style.bottom = data.val2Bottom || "96%";
        val2.style.transform = data.val2Transform || "translateX(0%)";
        
        path.style.transition = 'none';
        path.style.strokeDashoffset = '1000';
        path.style.strokeDasharray = '1000';
        
        document.getElementById('case-line-area').classList.remove('opacity-100');
        
        const dotsContainer = document.getElementById('case-line-dots-container');
        dotsContainer.innerHTML = '';
        
        document.getElementById('case-line-val-1').classList.remove('opacity-100', 'translate-y-0');
        document.getElementById('case-line-val-1').classList.add('translate-y-2');
        document.getElementById('case-line-val-2').classList.remove('opacity-100', 'translate-y-0');
        document.getElementById('case-line-val-2').classList.add('translate-y-2');
      } else if (type === 'pie') {
        document.getElementById('chart-pie-container').classList.remove('hidden');
        document.getElementById('case-pie-desc').innerText = data.pieDesc;
        document.getElementById('case-pie-val').innerText = "0%";
        document.getElementById('case-pie-path').style.strokeDashoffset = '251.2';
      } else {
        document.getElementById('chart-bar-container').classList.remove('hidden');
        document.getElementById('case-bar-1').style.height = '10%';
        document.getElementById('case-bar-2').style.height = '10%';
        
        document.getElementById('case-bar-val-1').innerText = data.val1;
        document.getElementById('case-bar-val-2').innerText = data.val2;
        document.getElementById('case-bar-val-1').classList.remove('opacity-100', 'translate-y-0');
        document.getElementById('case-bar-val-1').classList.add('translate-y-2');
        document.getElementById('case-bar-val-2').classList.remove('opacity-100', 'translate-y-0');
        document.getElementById('case-bar-val-2').classList.add('translate-y-2');
      }
      
      const scrollbarWidth = window.innerWidth - document.documentElement.clientWidth;
      document.body.style.paddingRight = `${scrollbarWidth}px`;
      document.body.style.overflow = 'hidden';
      
      cOverlay.classList.remove('opacity-0', 'pointer-events-none');
      cCard.classList.remove('scale-95', 'opacity-0');
      cCard.classList.add('scale-100', 'opacity-100');
      
      cancelAnimationFrame(counterAnimationFrame);
      cancelAnimationFrame(pieAnimationFrame);
      
      setTimeout(() => {
        if (type === 'line') {
          const path = document.getElementById('case-line-path');
          const svg = path.ownerSVGElement || path.viewportElement;
          
          path.style.transition = 'none';
          
          const userLength = path.getTotalLength();
          const svgRect = svg.getBoundingClientRect();
          const scaleX = svgRect.width / 100;
          const scaleY = svgRect.height / 100;
          const scale = Math.max(scaleX, scaleY);
          const pixelLength = userLength * scale * 1.15;
          
          path.style.strokeDasharray = pixelLength;
          path.style.strokeDashoffset = pixelLength;
          
          const dotsContainer = document.getElementById('case-line-dots-container');
          dotsContainer.innerHTML = '';
          if (data.points) {
            data.points.forEach((pt, idx) => {
              const dot = document.createElement('div');
              if (idx === data.points.length - 1) {
                dot.className = 'absolute w-4.5 h-4.5 bg-accent rounded-full border-2 border-white shadow-lg shadow-accent/30 animate-pulse transition-all duration-500 opacity-0 z-10';
              } else {
                dot.className = 'absolute w-3.5 h-3.5 bg-primary rounded-full border-2 border-white shadow-md transition-all duration-500 opacity-0 z-10';
              }
              dot.style.transform = 'translate(-50%, 50%)';
              dot.style.left = `${pt.x}%`;
              dot.style.bottom = `${100 - pt.y}%`;
              
              // Синхронизация задержки с прогрессом кривой Безье cubic-bezier(0.25, 1, 0.5, 1) - easeOutQuart
              const xNorm = pt.x / 100;
              const delaySec = Math.max(0, (1 - Math.pow(1 - xNorm, 0.25)) * 2.0 - 0.1);
              dot.style.transitionDelay = `${delaySec}s`;
              
              dotsContainer.appendChild(dot);
              
              setTimeout(() => {
                dot.classList.add('opacity-100');
              }, 50);
            });
          }
          
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              path.style.transition = 'stroke-dashoffset 2.0s cubic-bezier(0.25, 1, 0.5, 1)';
              path.style.strokeDashoffset = '0';
            });
          });
          
          document.getElementById('case-line-area').classList.add('opacity-100');
          
          const getDelay = (xPercent) => {
            const x = parseFloat(xPercent) / 100;
            return Math.max(0, (1 - Math.pow(1 - x, 0.25)) * 2000 - 100);
          };
          const delay1 = data.val1Left ? getDelay(data.val1Left) : 300;
          const delay2 = data.val2Left ? getDelay(data.val2Left) : 1600;
          
          if (data.val1) {
            setTimeout(() => {
              document.getElementById('case-line-val-1').classList.remove('translate-y-2');
              document.getElementById('case-line-val-1').classList.add('opacity-100', 'translate-y-0');
            }, delay1);
          }
          
          if (data.val2) {
            setTimeout(() => {
              document.getElementById('case-line-val-2').classList.remove('translate-y-2');
              document.getElementById('case-line-val-2').classList.add('opacity-100', 'translate-y-0');
            }, delay2);
          }
        } else if (type === 'pie') {
          document.getElementById('case-pie-path').style.strokeDashoffset = data.pieOffset;
          
          const targetPie = parseFloat(data.pieVal);
          const durationPie = 2000;
          const startTimePie = performance.now();
          
          const animatePie = (now) => {
            const elapsed = now - startTimePie;
            const progress = Math.min(elapsed / durationPie, 1);
            const easeProgress = 1 - Math.pow(1 - progress, 4); // easeOutQuart
            const current = Math.floor(easeProgress * targetPie);
            
            document.getElementById('case-pie-val').innerText = current + "%";
            
            if (progress < 1) {
              pieAnimationFrame = requestAnimationFrame(animatePie);
            } else {
              document.getElementById('case-pie-val').innerText = data.pieVal;
            }
          };
          pieAnimationFrame = requestAnimationFrame(animatePie);
        } else {
          document.getElementById('case-bar-1').style.height = data.bar1;
          document.getElementById('case-bar-2').style.height = data.bar2;
          
          document.getElementById('case-bar-val-1').classList.remove('translate-y-2');
          document.getElementById('case-bar-val-1').classList.add('opacity-100', 'translate-y-0');
          document.getElementById('case-bar-val-2').classList.remove('translate-y-2');
          document.getElementById('case-bar-val-2').classList.add('opacity-100', 'translate-y-0');
        }
        
        const targetNum = parseFloat(data.result.replace(/[^0-9.-]/g, ''));
        if (isNaN(targetNum)) {
          resEl.innerText = data.result + (data.resultSuffix || "");
        } else {
          const prefix = data.result.replace(/[0-9.-].*/, '');
          const durationCounter = 1500;
          const startTimeCounter = performance.now();
          
          const animateCounter = (now) => {
            const elapsed = now - startTimeCounter;
            const progress = Math.min(elapsed / durationCounter, 1);
            const easeProgress = 1 - Math.pow(1 - progress, 4); // easeOutQuart
            const current = Math.floor(easeProgress * targetNum);
            
            resEl.innerText = prefix + current + (data.resultSuffix || "");
            
            if (progress < 1) {
              counterAnimationFrame = requestAnimationFrame(animateCounter);
            } else {
              resEl.innerText = data.result + (data.resultSuffix || "");
            }
          };
          counterAnimationFrame = requestAnimationFrame(animateCounter);
        }
      }, 350);
    };

    window.closeCaseModal = function() {
      cOverlay.classList.add('opacity-0', 'pointer-events-none');
      cCard.classList.remove('scale-100', 'opacity-100');
      cCard.classList.add('scale-95', 'opacity-0');
      cancelAnimationFrame(counterAnimationFrame);
      cancelAnimationFrame(pieAnimationFrame);
      document.body.style.paddingRight = '';
      document.body.style.overflow = '';
    };

    

    cOverlay.addEventListener('click', (e) => {
      if (e.target === cOverlay) window.closeCaseModal();
    });

    

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        if (!cOverlay.classList.contains('opacity-0')) {
          window.closeCaseModal();
        }
        if (!mOverlay.classList.contains('opacity-0')) {
          window.closeMobileCaseModal();
        }
      }
    });
  
  })();
</script>
</section>
