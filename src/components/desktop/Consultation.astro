---
import Button from '../ui/Button.astro';
---

<div class="below-fold px-6 py-16 md:py-24 bg-background text-primary relative min-h-[calc(100dvh-5rem)] flex flex-col justify-center overflow-hidden border-t border-primary/10">
  <!-- Ambient glow background decoration -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-accent/5 rounded-full blur-[120px] pointer-events-none -z-10" style="will-change: transform; transform: translateZ(0);"></div>
  
  <div class="max-w-7xl mx-auto w-full z-10 relative">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      
      <!-- Left Column: Info/Marketing text -->
      <div class="lg:col-span-5 flex flex-col text-left reveal">
        <!-- Logo and Name -->
        <div class="flex items-center gap-0 mb-6">
          <img src="/logo.png" alt="Stratum Agency Logo" class="w-20 h-20 md:w-24 md:h-24 object-contain mix-blend-multiply -ml-2" loading="lazy" decoding="async" />
          <h3 class="text-4xl md:text-5xl font-extrabold text-primary tracking-tight -ml-2">Stratum<span class="text-accent">Agency</span></h3>
        </div>
        
        <!-- Big Catchy Headline -->
        <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-4xl xl:text-5xl font-extrabold text-primary mb-6 leading-tight tracking-tight">
          <span class="whitespace-nowrap block">Свяжитесь с нами и</span>
          <span class="whitespace-nowrap block">получите бесплатную</span>
          <span class="whitespace-nowrap block">консультацию</span>
        </h2>
        
        <p class="text-primary/70 text-lg md:text-xl leading-relaxed font-medium">
          Мы детально разберем текущее состояние вашего бизнеса, проанализируем конкурентов в вашем сегменте и предложим пошаговый план по привлечению клиентов через SEO, чат-боты и SMM.
        </p>
      </div>

      <!-- Right Column: Form Container (Explicit dark background to keep it looking dark) -->
      <div class="lg:col-span-7 reveal">
        <div class="bg-primary border border-white/10 rounded-[3rem] p-8 md:p-12 shadow-[0_20px_50px_rgba(26,37,48,0.25)] relative overflow-hidden">
          <!-- Small visual highlights inside the card -->
          <div class="absolute -top-32 -right-32 w-72 h-72 bg-accent/20 rounded-full blur-[70px] pointer-events-none -z-10 animate-pulse" style="animation-duration: 8s; will-change: transform, opacity; transform: translateZ(0);"></div>
          <div class="absolute -bottom-32 -left-32 w-72 h-72 bg-white/5 rounded-full blur-[60px] pointer-events-none -z-10" style="will-change: transform; transform: translateZ(0);"></div>
          
          <form class="space-y-4 w-full relative z-10" onsubmit="event.preventDefault(); alert('Заявка отправлена!'); this.reset();">
            <div>
              <input type="text" required class="w-full px-5 py-4 rounded-2xl border border-white/10 bg-white/5 text-white placeholder-white/40 focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/25 focus:bg-primary/30 shadow-sm transition-all duration-300 font-semibold" placeholder="Ваше имя">
            </div>
            <div>
              <input type="email" required class="w-full px-5 py-4 rounded-2xl border border-white/10 bg-white/5 text-white placeholder-white/40 focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/25 focus:bg-primary/30 shadow-sm transition-all duration-300 font-semibold" placeholder="Ваш Email">
            </div>
            <div>
              <input type="text" class="w-full px-5 py-4 rounded-2xl border border-white/10 bg-white/5 text-white placeholder-white/40 focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/25 focus:bg-primary/30 shadow-sm transition-all duration-300 font-semibold" placeholder="Ваш Telegram (@username)">
            </div>
            <div>
              <input type="tel" required class="w-full px-5 py-4 rounded-2xl border border-white/10 bg-white/5 text-white placeholder-white/40 focus:outline-none focus:border-accent focus:ring-2 focus:ring-accent/25 focus:bg-primary/30 shadow-sm transition-all duration-300 font-semibold" placeholder="Ваш телефон">
            </div>
            
            <div class="space-y-4 pt-1">
              <label class="flex items-start gap-3 text-white/50 text-sm cursor-pointer group">
                <div class="relative flex items-center justify-center mt-0.5 shrink-0">
                  <input type="checkbox" required class="peer sr-only">
                  <div class="w-5 h-5 rounded-md border border-white/20 bg-white/5 group-hover:border-accent/50 peer-checked:bg-accent peer-checked:border-accent peer-focus-visible:ring-2 peer-focus-visible:ring-accent/50 peer-checked:[&>svg]:scale-100 peer-checked:[&>svg]:opacity-100 flex items-center justify-center transition-all duration-300">
                    <svg class="w-3.5 h-3.5 text-white scale-0 opacity-0 transition-all duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </div>
                </div>
                <span class="group-hover:text-white transition-colors leading-tight font-medium select-none">
                  Я соглашаюсь с <a href="/docs/privacy.pdf" target="_blank" onclick="event.stopPropagation()" class="text-red-500 hover:text-red-400 underline font-semibold transition-colors">политикой конфиденциальности</a> и <a href="/docs/personal-data.pdf" target="_blank" onclick="event.stopPropagation()" class="text-red-500 hover:text-red-400 underline font-semibold transition-colors">обработкой персональных данных</a>
                </span>
              </label>
              <label class="flex items-start gap-3 text-white/50 text-sm cursor-pointer group">
                <div class="relative flex items-center justify-center mt-0.5 shrink-0">
                  <input type="checkbox" required class="peer sr-only">
                  <div class="w-5 h-5 rounded-md border border-white/20 bg-white/5 group-hover:border-accent/50 peer-checked:bg-accent peer-checked:border-accent peer-focus-visible:ring-2 peer-focus-visible:ring-accent/50 peer-checked:[&>svg]:scale-100 peer-checked:[&>svg]:opacity-100 flex items-center justify-center transition-all duration-300">
                    <svg class="w-3.5 h-3.5 text-white scale-0 opacity-0 transition-all duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </div>
                </div>
                <span class="group-hover:text-white transition-colors leading-tight font-medium select-none">
                  Я согласен получать <a href="/docs/marketing-consent.pdf" target="_blank" onclick="event.stopPropagation()" class="text-red-500 hover:text-red-400 underline font-semibold transition-colors">рекламную рассылку</a>
                </span>
              </label>
            </div>

            <Button variant="primary" class="w-full mt-4 py-4.5 text-xl font-extrabold shadow-xl shadow-accent/20 hover:shadow-accent/40 rounded-2xl" type="submit" aria-label="Отправить форму">
              Отправить заявку
            </Button>
          </form>
        </div>
      </div>
      
    </div>
  </div>
</div>
