---
---

<div class="below-fold px-6 py-16 md:py-24 bg-white relative min-h-[calc(100dvh-5rem)] flex flex-col justify-center overflow-hidden">
  <!-- Ambient glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-accent/5 rounded-full blur-[100px] pointer-events-none -z-10" style="will-change: transform; transform: translateZ(0);"></div>

  <div class="max-w-5xl mx-auto z-10 relative">
    <div class="text-center mb-16 reveal">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/5 border border-primary/10 mb-6 hover:bg-primary/10 transition-colors cursor-default">
        <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
        <span class="text-sm font-medium text-primary/70 uppercase tracking-wider">Ответы</span>
      </div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-primary tracking-tight leading-none mb-6">Частые вопросы</h2>
    </div>

    <!-- Slider Wrapper with Side Navigation -->
    <div class="flex flex-col lg:flex-row items-center gap-6 lg:gap-8 relative">
      
      <!-- Left Arrow (Desktop only) -->
      <button id="faq-prev-btn" class="hidden lg:flex w-14 h-14 rounded-full border border-primary/10 bg-white items-center justify-center text-primary hover:text-accent hover:border-accent/30 hover:scale-105 transition-all duration-300 shadow-md shrink-0 opacity-0 pointer-events-none z-10 cursor-pointer" aria-label="Предыдущие вопросы">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
      </button>

      <!-- Track wrapper -->
      <div class="w-full overflow-hidden px-8 -mx-8 py-16 -my-16">
        <div id="faq-track" class="flex transition-transform duration-500 ease-out w-[200%]" style="transform: translateX(0%);">
          
          <!-- Page 1 (Questions 1-3) -->
          <div class="w-1/2 grid gap-5 pr-1 lg:pr-3 shrink-0">
            <!-- Question 1 -->
            <button onclick="openFaq(0)" class="w-full text-left group relative bg-white border border-primary/5 rounded-2xl md:rounded-[2rem] p-5 lg:p-8 hover:border-accent/30 hover:shadow-[0_15px_45px_rgba(26,37,48,0.06)] hover:-translate-y-0.5 transition-all duration-500 ease-out flex justify-between items-center overflow-hidden cursor-pointer reveal">
              <div class="absolute inset-0 bg-gradient-to-r from-accent/0 via-accent/5 to-accent/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <span class="text-xl lg:text-2xl font-bold text-primary tracking-tight relative z-10 group-hover:text-accent transition-colors">Как быстро окупятся ваши услуги?</span>
              <div class="w-14 h-14 shrink-0 rounded-full bg-primary/5 flex items-center justify-center group-hover:bg-accent/10 group-hover:scale-110 transition-all duration-500 relative z-10 ml-4 shadow-sm">
                <svg class="w-7 h-7 text-primary group-hover:text-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
              </div>
            </button>

            <!-- Question 2 -->
            <button onclick="openFaq(1)" class="w-full text-left group relative bg-white border border-primary/5 rounded-2xl md:rounded-[2rem] p-5 lg:p-8 hover:border-accent/30 hover:shadow-[0_15px_45px_rgba(26,37,48,0.06)] hover:-translate-y-0.5 transition-all duration-500 ease-out flex justify-between items-center overflow-hidden cursor-pointer reveal">
              <div class="absolute inset-0 bg-gradient-to-r from-accent/0 via-accent/5 to-accent/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <span class="text-xl lg:text-2xl font-bold text-primary tracking-tight relative z-10 group-hover:text-accent transition-colors">Когда я увижу первые результаты в виде новых клиентов?</span>
              <div class="w-14 h-14 shrink-0 rounded-full bg-primary/5 flex items-center justify-center group-hover:bg-accent/10 group-hover:scale-110 transition-all duration-500 relative z-10 ml-4 shadow-sm">
                <svg class="w-7 h-7 text-primary group-hover:text-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
              </div>
            </button>

            <!-- Question 3 -->
            <button onclick="openFaq(2)" class="w-full text-left group relative bg-white border border-primary/5 rounded-2xl md:rounded-[2rem] p-5 lg:p-8 hover:border-accent/30 hover:shadow-[0_15px_45px_rgba(26,37,48,0.06)] hover:-translate-y-0.5 transition-all duration-500 ease-out flex justify-between items-center overflow-hidden cursor-pointer reveal">
              <div class="absolute inset-0 bg-gradient-to-r from-accent/0 via-accent/5 to-accent/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <span class="text-xl lg:text-2xl font-bold text-primary tracking-tight relative z-10 group-hover:text-accent transition-colors">Что будет после того, как вы внедрите систему?</span>
              <div class="w-14 h-14 shrink-0 rounded-full bg-primary/5 flex items-center justify-center group-hover:bg-accent/10 group-hover:scale-110 transition-all duration-500 relative z-10 ml-4 shadow-sm">
                <svg class="w-7 h-7 text-primary group-hover:text-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
              </div>
            </button>
          </div>

          <!-- Page 2 (Questions 4-6) -->
          <div class="w-1/2 grid gap-5 pl-1 lg:pl-3 shrink-0">
            <!-- Question 4 -->
            <button onclick="openFaq(3)" class="w-full text-left group relative bg-white border border-primary/5 rounded-2xl md:rounded-[2rem] p-5 lg:p-8 hover:border-accent/30 hover:shadow-[0_15px_45px_rgba(26,37,48,0.06)] hover:-translate-y-0.5 transition-all duration-500 ease-out flex justify-between items-center overflow-hidden cursor-pointer reveal">
              <div class="absolute inset-0 bg-gradient-to-r from-accent/0 via-accent/5 to-accent/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <span class="text-xl lg:text-2xl font-bold text-primary tracking-tight relative z-10 group-hover:text-accent transition-colors">Мне придется во всем этом разбираться?</span>
              <div class="w-14 h-14 shrink-0 rounded-full bg-primary/5 flex items-center justify-center group-hover:bg-accent/10 group-hover:scale-110 transition-all duration-500 relative z-10 ml-4 shadow-sm">
                <svg class="w-7 h-7 text-primary group-hover:text-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
              </div>
            </button>

            <!-- Question 5 -->
            <button onclick="openFaq(4)" class="w-full text-left group relative bg-white border border-primary/5 rounded-2xl md:rounded-[2rem] p-5 lg:p-8 hover:border-accent/30 hover:shadow-[0_15px_45px_rgba(26,37,48,0.06)] hover:-translate-y-0.5 transition-all duration-500 ease-out flex justify-between items-center overflow-hidden cursor-pointer reveal">
              <div class="absolute inset-0 bg-gradient-to-r from-accent/0 via-accent/5 to-accent/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <span class="text-xl lg:text-2xl font-bold text-primary tracking-tight relative z-10 group-hover:text-accent transition-colors">А вдруг вы не поймете специфику моего бизнеса?</span>
              <div class="w-14 h-14 shrink-0 rounded-full bg-primary/5 flex items-center justify-center group-hover:bg-accent/10 group-hover:scale-110 transition-all duration-500 relative z-10 ml-4 shadow-sm">
                <svg class="w-7 h-7 text-primary group-hover:text-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
              </div>
            </button>

            <!-- Question 6 -->
            <button onclick="openFaq(5)" class="w-full text-left group relative bg-white border border-primary/5 rounded-2xl md:rounded-[2rem] p-5 lg:p-8 hover:border-accent/30 hover:shadow-[0_15px_45px_rgba(26,37,48,0.06)] hover:-translate-y-0.5 transition-all duration-500 ease-out flex justify-between items-center overflow-hidden cursor-pointer reveal">
              <div class="absolute inset-0 bg-gradient-to-r from-accent/0 via-accent/5 to-accent/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <span class="text-xl lg:text-2xl font-bold text-primary tracking-tight relative z-10 group-hover:text-accent transition-colors">Не отпугнет ли чат-бот моих клиентов?</span>
              <div class="w-14 h-14 shrink-0 rounded-full bg-primary/5 flex items-center justify-center group-hover:bg-accent/10 group-hover:scale-110 transition-all duration-500 relative z-10 ml-4 shadow-sm">
                <svg class="w-7 h-7 text-primary group-hover:text-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
              </div>
            </button>
          </div>

        </div>
      </div>

      <!-- Right Arrow (Desktop only) -->
      <button id="faq-next-btn" class="hidden lg:flex w-14 h-14 rounded-full border border-primary/10 bg-white items-center justify-center text-primary hover:text-accent hover:border-accent/30 hover:scale-105 transition-all duration-300 shadow-md shrink-0 z-10 cursor-pointer" aria-label="Следующие вопросы">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      </button>

    </div>

    <!-- Mobile Navigation Controls (only visible on mobile/tablet) -->
    <div class="flex lg:hidden items-center justify-center gap-4 mt-8">
      <button id="faq-prev-btn-mobile" class="w-12 h-12 rounded-full border border-primary/10 bg-white flex items-center justify-center text-primary hover:text-accent opacity-30 pointer-events-none transition-all duration-300 shadow-sm cursor-pointer" aria-label="Предыдущие вопросы">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
      </button>
      
      <span id="faq-indicator-mobile" class="text-sm font-bold text-primary/60 select-none">1 / 2</span>
      
      <button id="faq-next-btn-mobile" class="w-12 h-12 rounded-full border border-primary/10 bg-white flex items-center justify-center text-primary hover:text-accent transition-all duration-300 shadow-sm cursor-pointer" aria-label="Следующие вопросы">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
  </div>
</div>
</div>

<!-- Interactive Modal/Popup for Answers (Outside below-fold to prevent viewport clipping) -->
<div id="faq-popup-overlay" class="fixed inset-0 bg-primary/40 backdrop-blur-md z-[100] opacity-0 pointer-events-none transition-opacity duration-500 flex items-center justify-center px-4">
  <div id="faq-popup-card" class="bg-background w-full max-w-3xl rounded-[3rem] p-8 md:p-14 border border-primary/10 shadow-[0_20px_50px_rgba(26,37,48,0.15)] transform scale-95 opacity-0 transition-all duration-500 relative overflow-hidden">
      <!-- Decor in popup -->
      <div class="absolute -top-32 -right-32 w-64 h-64 bg-accent/5 rounded-full blur-[60px] pointer-events-none -z-10"></div>

      <button onclick="closeFaq()" class="absolute top-6 right-6 md:top-8 md:right-8 w-14 h-14 bg-primary/5 hover:bg-accent/10 hover:shadow-lg rounded-full flex items-center justify-center text-primary hover:text-accent transition-all duration-300 group z-10 cursor-pointer" aria-label="Закрыть">
        <svg class="w-8 h-8 group-hover:rotate-90 transition-transform duration-300 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
      
      <div class="relative z-10">
        <div class="inline-flex items-center justify-center w-20 h-20 rounded-3xl bg-accent/10 border border-accent/20 text-accent mb-8 shadow-sm">
          <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
        </div>
        <h3 id="faq-popup-title" class="text-3xl md:text-5xl font-black text-primary tracking-tight mb-8 leading-tight"></h3>
        <p id="faq-popup-body" class="text-xl md:text-2xl text-primary/80 leading-relaxed font-semibold"></p>
      </div>
    </div>
  </div>

  <script is:inline>
  (() => {

    const faqs = [
      {
        title: "Как быстро окупятся ваши услуги?",
        body: "Мы понимаем, что для малого бизнеса маркетинг — это всегда риск, а деньги бизнеса часто тесно сплетены с личным кошельком. Поэтому мы не предлагаем ждать результатов полгода ради абстрактного «повышения лояльности». Наша система направлена на закрытие дыр, через которые вы теряете деньги прямо сейчас: бот моментально ответит клиенту ночью, а SEO на картах приведет горячих людей «с улицы». По итогам мы предоставляем отчет «как было/как стало» с выделением конкретных результатов, чтобы вы наглядно видели отдачу от инвестиций."
      },
      {
        title: "Когда я увижу первые результаты в виде новых клиентов?",
        body: "Зависит от выбранных инструментов. Внедрение чат-ботов и публикация роликов по нашим сценариям может дать заявки уже в первые две недели. SEO-оптимизация на Яндекс.Картах и сайте имеет накопительный эффект — заметный рост трафика обычно происходит после 4 недели работы оптимизированной карточки."
      },
      {
        title: "Что будет после того, как вы внедрите систему?",
        body: "Мы не бросаем клиентов один на один с новыми инструментами. Во-первых, после проведения оптимизации вы получаете подробный отчет о том, какие проблемы были исправлены и как именно это сделано. Во-вторых, для консалтинг-услуг (боты) и комплексного ведения Instagram мы обеспечиваем поддержку: например, есть возможность бесплатно изменять контент внутри бота в зависимости от сроков контент-плана. Мы выстраиваем систему, которая продолжает работать на вас долгое время."
      },
      {
        title: "Мне придется во всем этом разбираться?",
        body: "Абсолютно нет. Мы понимаем, что у вас нет времени вникать в технические дебри и сложные маркетинговые термины. Наш слоган — «оптимизация малого бизнеса под ключ». Мы берем на себя всю техническую реализацию: от выделения семантического ядра до написания логики работы бота и его интеграции с CRM-системой. Вам не нужно ничего программировать или настраивать, мы сдаем полностью готовую и работающую систему."
      },
      {
        title: "А вдруг вы не поймете специфику моего бизнеса?",
        body: "Мы категорически против шаблонных постов, которые не приносят реальных записей. Именно поэтому любой проект начинается с глубокого погружения в вашу деятельность и глубинного анализа целевой аудитории с выявлением их страхов и желаний. Мы прописываем живые человеческие сценарии для SMM и ботов, чтобы общение выглядело естественно, экспертно и вызывало доверие у ваших клиентов."
      },
      {
        title: "Не отпугнет ли чат-бот моих клиентов?",
        body: "Мы не внедряем раздражающих ботов с тупиковыми скриптами. Наш виртуальный менеджер для Instagram или Telegram отвечает клиенту за пару секунд даже ночью, исключая человеческий фактор. Он мягко консультирует, помогает с записью и экономит время ваших администраторов, не давая горячему лиду уйти к конкурентам из-за долгого ожидания."
      }
    ];

    const overlay = document.getElementById('faq-popup-overlay');
    const card = document.getElementById('faq-popup-card');
    const titleEl = document.getElementById('faq-popup-title');
    const bodyEl = document.getElementById('faq-popup-body');

    window.openFaq = function(index) {
      const faq = faqs[index];
      titleEl.innerText = faq.title;
      bodyEl.innerText = faq.body;
      
      overlay.classList.remove('opacity-0', 'pointer-events-none');
      card.classList.remove('scale-95', 'opacity-0');
      card.classList.add('scale-100', 'opacity-100');
      document.body.style.overflow = 'hidden';
    };

    window.closeFaq = function() {
      overlay.classList.add('opacity-0', 'pointer-events-none');
      card.classList.remove('scale-100', 'opacity-100');
      card.classList.add('scale-95', 'opacity-0');
      document.body.style.overflow = '';
    };

    // Закрытие по клику вне окна
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) {
        window.closeFaq();
      }
    });

    // Закрытие по кнопке Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !overlay.classList.contains('opacity-0')) {
        window.closeFaq();
      }
    });

    // FAQ Slider Logic
    let currentFaqPage = 0;
    const faqTrack = document.getElementById('faq-track');
    const prevBtn = document.getElementById('faq-prev-btn');
    const nextBtn = document.getElementById('faq-next-btn');
    const prevBtnMobile = document.getElementById('faq-prev-btn-mobile');
    const nextBtnMobile = document.getElementById('faq-next-btn-mobile');
    const mobileIndicator = document.getElementById('faq-indicator-mobile');

    function switchFaqPage(page) {
      if (page < 0 || page > 1) return;
      currentFaqPage = page;
      
      // Сдвигаем на 1/2 ширины трека за страницу (track has 200% width, so each page is 50% offset)
      const offset = -page * 50;
      faqTrack.style.transform = `translateX(${offset}%)`;

      // Обновляем видимость десктопных стрелок
      if (page === 0) {
        prevBtn.classList.add('opacity-0', 'pointer-events-none');
        nextBtn.classList.remove('opacity-0', 'pointer-events-none');
      } else {
        prevBtn.classList.remove('opacity-0', 'pointer-events-none');
        nextBtn.classList.add('opacity-0', 'pointer-events-none');
      }

      // Обновляем состояние мобильных кнопок
      if (page === 0) {
        prevBtnMobile.classList.add('opacity-30', 'pointer-events-none');
        nextBtnMobile.classList.remove('opacity-30', 'pointer-events-none');
      } else {
        prevBtnMobile.classList.remove('opacity-30', 'pointer-events-none');
        nextBtnMobile.classList.add('opacity-30', 'pointer-events-none');
      }

      // Обновляем индикатор страниц
      if (mobileIndicator) {
        mobileIndicator.innerText = `${page + 1} / 2`;
      }
    }

    if (prevBtn) prevBtn.addEventListener('click', () => switchFaqPage(currentFaqPage - 1));
    if (nextBtn) nextBtn.addEventListener('click', () => switchFaqPage(currentFaqPage + 1));
    if (prevBtnMobile) prevBtnMobile.addEventListener('click', () => switchFaqPage(currentFaqPage - 1));
    if (nextBtnMobile) nextBtnMobile.addEventListener('click', () => switchFaqPage(currentFaqPage + 1));
  
  })();
</script>
