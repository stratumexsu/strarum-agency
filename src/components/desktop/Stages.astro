---
import Button from '../ui/Button.astro';

const stages = [
  {
    num: "01",
    title: "Аудит",
    short: "Первоначальный аудит компании и выделение слабых мест в текущей системе.",
    detail: "Глубокое погружение в бизнес-процессы вашей компании. Мы проводим полный аудит вашего бизнеса в сети: оцениваем SMM, локальное SEO и процесс обработки заявок. Наша цель — выявить слабые места, где бизнес теряет органический трафик, упускает звонки и отдает прибыль конкурентам. Вы получаете честную, оцифрованную картину текущей ситуации и понимание, почему старые методы перестали работать."
  },
  {
    num: "02",
    title: "Аналитика",
    short: "Глубинный анализ ЦА + детальный аудит процессов с выявлением потенциальных точек роста.",
    detail: "Чтобы система приносила деньги, нужно понимать тех, кто платит. Мы проводим глубинный анализ целевой аудитории: исследуем их реальные страхи, инсайты и желания. Это позволяет нам точно понять, почему люди уходят без покупки и как вернуть их за счет апсейла. На основе этих данных мы составляем пошаговый план оптимизации, который бьет точно в цель, а не строится на догадках."
  },
  {
    num: "03",
    title: "Оптимизация",
    short: "Проведение оптимизации бизнеса, внедрение воронок, ботов и контент-стратегий.",
    detail: "Переходим от теории к практике и забираем всю рутину на себя. Мы настраиваем контент-матрицу, выводим карточку на Яндексе в топ по району и внедряем умных ботов (TG/IG) для круглосуточной записи. Мы работаем полностью самостоятельно. От вас не требуется писать тексты или контролировать каждый наш шаг — мы просто превращаем ваш бизнес в отлаженный механизм по генерации лидов."
  },
  {
    num: "04",
    title: "Результат",
    short: "Предоставление отчетности «было/стало», выделение ожидаемых результатов и сроков.",
    detail: "По итогам работы вы получаете подробный и понятный отчет о том, какие конкретно проблемы были исправлены. Мы показываем результаты в твердом формате «как было / как стало», выделяем сроки получения новых результатов и даем стратегию удержания аудитории. Итог: сэкономленное время сотрудников и новый трафик, готовый к покупке."
  }
];
---

<section id="stages" class="below-fold px-6 py-16 md:py-24 bg-primary relative overflow-hidden text-white min-h-[calc(100dvh-5rem)] flex flex-col justify-center">
  <!-- Subtle background glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-accent/5 rounded-full blur-[120px] pointer-events-none z-0" style="will-change: transform; transform: translateZ(0);"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-12 lg:mb-16 tracking-tight reveal">
      Этапы <span class="text-accent">оптимизации</span>
    </h2>

    <!-- DESKTOP VERSION (lg:block) -->
    <div class="hidden lg:block">
      <div class="relative mb-16">
        <!-- Horizontal line (Desktop only) -->
        <div class="hidden lg:block absolute top-[28px] left-1/2 -translate-x-1/2 w-[200vw] h-[2px] bg-white/10 z-0">
          <div id="progress-line" class="absolute top-0 left-0 h-full bg-accent transition-all duration-500 ease-out" style="width: 0px;"></div>
        </div>

        <div class="flex flex-col lg:flex-row lg:justify-between gap-8 lg:gap-4 relative z-10" id="stages-container">
          {stages.map((stage, index) => (
            <div class="stage-item cursor-pointer group flex flex-col items-start lg:w-[23%] transition-transform duration-300 reveal" data-index={index}>
              <!-- Circle/Number -->
              <div class="relative z-10 w-14 h-14 rounded-full border-2 border-white/20 bg-primary flex items-center justify-center mb-6 transition-all duration-300 stage-circle group-hover:border-accent">
                <span class="text-xl font-bold text-white/50 stage-number transition-colors group-hover:text-white">{stage.num}</span>
              </div>
              
              <!-- Content -->
              <div>
                <h3 class="text-2xl font-bold mb-3 transition-colors stage-title group-hover:text-accent">{stage.title}</h3>
                <p class="text-white/60 text-sm leading-relaxed transition-colors stage-short">{stage.short}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Details Box -->
      <div id="details-box" class="bg-white/[0.02] border border-white/10 rounded-[2.5rem] p-12 reveal min-h-[320px] flex flex-col justify-between shadow-2xl backdrop-blur-md relative overflow-hidden z-10">
        <div class="absolute -top-24 -right-24 w-64 h-64 bg-accent/10 rounded-full blur-[80px] pointer-events-none -z-10" style="will-change: transform; transform: translateZ(0);"></div>
        
        <div>
          <div class="flex items-center gap-4 mb-6">
            <span id="detail-num" class="text-accent font-black text-5xl md:text-6xl opacity-80 leading-none transition-all duration-300 select-none">01</span>
            <h4 id="detail-title" class="text-3xl md:text-4xl font-bold leading-none transition-all duration-300">Аудит</h4>
          </div>
          <p id="detail-text" class="text-white/80 text-lg md:text-xl leading-relaxed max-w-4xl mb-10 transition-opacity duration-300 font-medium">
            {stages[0].detail}
          </p>
        </div>
        
        <div>
          <Button variant="primary" onclick="document.getElementById('consultation').scrollIntoView({ behavior: 'smooth' })" class="text-lg px-10 py-4 shadow-lg shadow-accent/20 hover:shadow-accent/40">
            Получить консультацию
          </Button>
        </div>
      </div>
    </div>

    </section>

<script is:inline>
  (() => {

  const stagesData = [
    { num: "01", title: "Аудит", detail: "Глубокое погружение в бизнес-процессы вашей компании. Мы проводим полный аудит вашего бизнеса в сети: оцениваем SMM, локальное SEO и процесс обработки заявок. Наша цель — выявить слабые места, где бизнес теряет органический трафик, упускает звонки и отдает прибыль конкурентам. Вы получаете честную, оцифрованную картину текущей ситуации и понимание, почему старые методы перестали работать." },
    { num: "02", title: "Аналитика", detail: "Чтобы система приносила деньги, нужно понимать тех, кто платит. Мы проводим глубинный анализ целевой аудитории: исследуем их реальные страхи, инсайты и желания. Это позволяет нам точно понять, почему люди уходят без покупки и как вернуть их за счет апсейла. На основе этих данных мы составляем пошаговый план оптимизации, который бьет точно в цель, а не строится на догадках." },
    { num: "03", title: "Оптимизация", detail: "Переходим от теории к практике и забираем всю рутину на себя. Мы настраиваем контент-матрицу, выводим карточку на Яндексе в топ по району и внедряем умных ботов (TG/IG) для круглосуточной записи. Мы работаем полностью самостоятельно. От вас не требуется писать тексты или контролировать каждый наш шаг — мы просто превращаем ваш бизнес в отлаженный механизм по генерации лидов." },
    { num: "04", title: "Результат", detail: "По итогам работы вы получаете подробный и понятный отчет о том, какие конкретно проблемы были исправлены. Мы показываем результаты в твердом формате «как было / как стало», выделяем сроки получения новых результатов и даем стратегию удержания аудитории. Итог: сэкономленное время сотрудников и новый трафик, готовый к покупке." }
  ];

  const items = document.querySelectorAll('.stage-item');
  const detailNum = document.getElementById('detail-num');
  const detailTitle = document.getElementById('detail-title');
  const detailText = document.getElementById('detail-text');
  const progressLine = document.getElementById('progress-line');

  function setActiveStage(index) {
    let activeCircleRect = null;
    
    items.forEach((item, i) => {
      const circle = item.querySelector('.stage-circle');
      const number = item.querySelector('.stage-number');
      const title = item.querySelector('.stage-title');
      const short = item.querySelector('.stage-short');
      
      if (i === parseInt(index)) {
        // Active state
        circle.classList.add('border-accent', 'scale-110');
        circle.classList.remove('border-white/20');
        number.classList.add('text-accent');
        number.classList.remove('text-white/50');
        title.classList.add('text-accent');
        short.classList.add('text-white/90');
        short.classList.remove('text-white/60');
        
        activeCircleRect = circle.getBoundingClientRect();
      } else {
        // Inactive state
        circle.classList.remove('border-accent', 'scale-110');
        circle.classList.add('border-white/20');
        number.classList.remove('text-accent');
        number.classList.add('text-white/50');
        title.classList.remove('text-accent');
        short.classList.remove('text-white/90');
        short.classList.add('text-white/60');
      }
    });

    // Update progress line width
    if (activeCircleRect && progressLine) {
      const width = (window.innerWidth / 2) + activeCircleRect.left + (activeCircleRect.width / 2);
      progressLine.style.width = width + 'px';
    }

    // Fade out text, update, fade in
    detailText.style.opacity = '0';
    detailNum.style.opacity = '0';
    detailTitle.style.opacity = '0';
    
    setTimeout(() => {
      detailNum.textContent = stagesData[index].num;
      detailTitle.textContent = stagesData[index].title;
      detailText.textContent = stagesData[index].detail;
      
      detailText.style.opacity = '1';
      detailText.innerText = stagesData[index].detail;
      detailText.classList.remove('opacity-0', 'translate-y-2');
      
      detailNum.style.opacity = '0.8';
      detailTitle.style.opacity = '1';

      // Auto-scroll to details box on mobile
      const box = document.getElementById('details-box');
      if (window.innerWidth < 1024 && box && box.offsetParent !== null) {
        box.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    }, 150);
  }

  // Initialize first stage
  setActiveStage(0);

  items.forEach(item => {
    item.addEventListener('click', () => {
      setActiveStage(item.getAttribute('data-index'));
    });
  });
  
  // Handle window resize to keep progress line accurate
  let resizeTimeout;
  window.addEventListener('resize', () => {
    if (resizeTimeout) clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(() => {
      requestAnimationFrame(() => {
        const activeItem = document.querySelector('.stage-circle.border-accent');
        if (activeItem && progressLine && progressLine.offsetParent !== null) {
          const activeCircleRect = activeItem.getBoundingClientRect();
          const width = (window.innerWidth / 2) + activeCircleRect.left + (activeCircleRect.width / 2);
          progressLine.style.width = width + 'px';
        }
      });
    }, 100);
  });

  })();
</script>
