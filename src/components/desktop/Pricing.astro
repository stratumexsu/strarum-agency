---
import Button from '../ui/Button.astro';
---

<div class="below-fold px-6 py-20 md:py-28 bg-background text-primary relative min-h-[calc(100dvh-5rem)] flex flex-col justify-center overflow-hidden">
  <!-- Glowing gradients and decorative spheres for premium aesthetic -->
  <div class="absolute top-1/3 left-1/4 w-[600px] h-[600px] bg-primary/3 rounded-full blur-[120px] pointer-events-none -z-10" style="will-change: transform; transform: translateZ(0);"></div>
  <div class="absolute bottom-10 right-1/4 w-[500px] h-[500px] bg-accent/4 rounded-full blur-[100px] pointer-events-none -z-10" style="will-change: transform; transform: translateZ(0);"></div>

  <div class="max-w-6xl mx-auto w-full relative z-10 flex flex-col h-full">
    
    <!-- Centered Premium Header with Badge -->
    <div class="text-center mb-8 md:mb-10 reveal">
      <div class="flex justify-center mb-6">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/5 border border-primary/10 select-none cursor-default">
          <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
          <span class="text-sm font-bold text-primary/70 uppercase tracking-wider">Прайс-лист</span>
        </div>
      </div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-primary mb-6 tracking-tight">Стоимость наших услуг</h2>
      <p class="text-lg text-primary/70 max-w-2xl mx-auto font-medium">Выберите интересующее вас направление.</p>
    </div>

    <!-- Tabbed Navigation Buttons (horizontal scrollable on mobile/tablet, centered on desktop) -->
    <div class="flex justify-start lg:justify-center items-center gap-3 overflow-x-auto no-scrollbar pt-4 pb-6 mb-4 -mx-6 px-6 lg:mx-0 lg:px-0 reveal">
      <button class="pricing-tab-desktop px-6 py-3 rounded-full border border-primary bg-primary text-white text-sm font-extrabold transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] whitespace-nowrap cursor-pointer shadow-[0_10px_25px_rgba(26,37,48,0.12)] active:scale-95 active:opacity-90 select-none" data-index="0">
        Комплексные решения
      </button>
      <button class="pricing-tab-desktop px-6 py-3 rounded-full border border-primary/10 bg-white/40 backdrop-blur-sm text-primary/70 text-sm font-extrabold transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] whitespace-nowrap cursor-pointer hover:border-accent/30 hover:bg-accent/[0.03] hover:text-accent hover:shadow-[0_6px_15px_rgba(107,29,47,0.04)] active:scale-95 active:opacity-90 select-none" data-index="1">
        SMM
      </button>
      <div class="relative">
        <button class="pricing-tab-desktop px-6 py-3 rounded-full border border-primary/10 bg-white/40 backdrop-blur-sm text-primary/70 text-sm font-extrabold transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] whitespace-nowrap cursor-pointer hover:border-primary/30 hover:bg-primary/[0.03] hover:text-primary hover:shadow-[0_6px_15px_rgba(26,37,48,0.04)] active:scale-95 active:opacity-90 select-none" data-index="2">
          Сайты и чат боты
        </button>
        <span class="absolute -top-3 left-1/2 -translate-x-1/2 px-2 py-0.5 rounded bg-accent text-white text-[9px] font-black uppercase tracking-wider shadow-md pointer-events-none select-none z-20 whitespace-nowrap">
          Новинка
        </span>
      </div>
      <button class="pricing-tab-desktop px-6 py-3 rounded-full border border-primary/10 bg-white/40 backdrop-blur-sm text-primary/70 text-sm font-extrabold transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] whitespace-nowrap cursor-pointer hover:border-accent/30 hover:bg-accent/[0.03] hover:text-accent hover:shadow-[0_6px_15px_rgba(107,29,47,0.04)] active:scale-95 active:opacity-90 select-none" data-index="3">
        SEO
      </button>
      <button class="pricing-tab-desktop px-6 py-3 rounded-full border border-primary/10 bg-white/40 backdrop-blur-sm text-primary/70 text-sm font-extrabold transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] whitespace-nowrap cursor-pointer hover:border-primary/30 hover:bg-primary/[0.03] hover:text-primary hover:shadow-[0_6px_15px_rgba(26,37,48,0.04)] active:scale-95 active:opacity-90 select-none" data-index="4">
        Точечные услуги
      </button>
    </div>

    <!-- Cards Container (with dynamic height transition styling) -->
    <div id="pricing-cards-container-desktop" class="max-w-4xl mx-auto w-full relative reveal" style="transition: height 350ms cubic-bezier(0.16, 1, 0.3, 1);">
      
      <!-- Card 1: Комплексные решения (Dark Card) -->
      <div class="pricing-card-desktop active w-full bg-gradient-to-br from-[#1A2530] via-[#141C25] to-[#0D1218] text-white rounded-3xl md:rounded-[2.5rem] p-6 md:p-12 border border-white/5 shadow-[0_30px_80px_-20px_rgba(13,18,24,0.18)] relative overflow-hidden transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]" data-index="0" style="opacity: 1; transform: translateY(0);">
        <!-- Radial Backlight Glow -->
        <div class="absolute -top-24 -right-24 w-[350px] h-[350px] bg-accent/8 rounded-full blur-[80px] pointer-events-none -z-10 animate-pulse" style="animation-duration: 8s; will-change: transform, opacity; transform: translateZ(0);"></div>
        
        <!-- Best Choice Badge -->
        <div class="absolute top-8 right-8 md:top-12 md:right-12">
          <span class="px-4 py-1.5 rounded-full bg-accent text-white text-xs font-extrabold uppercase tracking-widest border border-white/10 shadow-[0_4px_15px_rgba(107,29,47,0.3)]">Лучший выбор</span>
        </div>
        
        <h3 class="text-2xl md:text-3xl font-extrabold text-white tracking-tight mb-8">Комплексные решения</h3>
        <div class="w-full h-px bg-white/10 mb-6"></div>
        
        <div class="space-y-4">
          <!-- Item 1 -->
          <div class="stagger-row group/row relative flex justify-between items-center gap-6 p-4 -mx-4 rounded-2xl transition-all duration-300 hover:bg-white/[0.03] cursor-pointer" style="opacity: 0; transform: translateY(12px);">
            <div class="flex-1 min-w-0">
              <h4 class="text-lg md:text-xl font-bold tracking-tight mb-1 text-white transition-colors duration-300">Полная оптимизация бизнеса</h4>
              <p class="text-sm text-white/60 transition-colors duration-300 group-hover/row:text-white/80">SMM + SEO + внедрение ботов</p>
            </div>
            <div class="text-xl md:text-2xl lg:text-3xl font-extrabold text-right shrink-0 whitespace-nowrap text-white">
              от 15 000 ₽
            </div>
          </div>
          
          <div class="w-full h-px bg-white/5"></div>
          
          <!-- Item 2 -->
          <div class="stagger-row group/row relative flex justify-between items-center gap-6 p-4 -mx-4 rounded-2xl transition-all duration-300 hover:bg-white/[0.03] cursor-pointer" style="opacity: 0; transform: translateY(12px);">
            <div class="flex-1 min-w-0">
              <h4 class="text-lg md:text-xl font-bold tracking-tight mb-1 text-white transition-colors duration-300">Комплексное ведение Instagram</h4>
              <p class="text-sm text-white/60 transition-colors duration-300 group-hover/row:text-white/80">Контент матрица + сценарии Reels + написание постов + бот</p>
            </div>
            <div class="text-xl md:text-2xl lg:text-3xl font-extrabold text-right shrink-0 whitespace-nowrap text-white">
              11 000 ₽
            </div>
          </div>
        </div>
      </div>

      <!-- Card 2: SMM (Light Card) -->
      <div class="pricing-card-desktop hidden w-full bg-gradient-to-b from-white to-[#FBF9F4] text-primary rounded-3xl md:rounded-[2.5rem] p-6 md:p-12 border border-primary/5 shadow-[0_30px_80px_-20px_rgba(26,37,48,0.03)] relative overflow-hidden transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]" data-index="1" style="opacity: 0; transform: translateY(6px);">
        <!-- Top Accent Glow Line -->
        <div class="absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r from-accent to-[#942C41]"></div>
        
        <h3 class="text-2xl md:text-3xl font-extrabold text-primary tracking-tight mb-8">SMM</h3>
        <div class="w-full h-px bg-primary/10 mb-6"></div>
        
        <div class="space-y-4">
          <!-- Item 1 -->
          <div class="stagger-row group/row relative flex justify-between items-center gap-6 p-4 -mx-4 rounded-2xl transition-all duration-300 hover:bg-primary/[0.02] cursor-pointer" style="opacity: 0; transform: translateY(12px);">
            <div class="flex-1 min-w-0">
              <h4 class="text-lg md:text-xl font-bold tracking-tight mb-1 text-primary transition-colors duration-300">Составление контент-матрицы</h4>
              <p class="text-sm text-primary/60 transition-colors duration-300 group-hover/row:text-primary/80">Вовлечение + прогрев + удержание</p>
            </div>
            <div class="text-xl md:text-2xl lg:text-3xl font-extrabold text-right shrink-0 whitespace-nowrap text-accent">
              2 500 ₽
            </div>
          </div>
          
          <div class="w-full h-px bg-primary/5"></div>
          
          <!-- Item 2 -->
          <div class="stagger-row group/row relative flex justify-between items-center gap-6 p-4 -mx-4 rounded-2xl transition-all duration-300 hover:bg-primary/[0.02] cursor-pointer" style="opacity: 0; transform: translateY(12px);">
            <div class="flex-1 min-w-0">
              <h4 class="text-lg md:text-xl font-bold tracking-tight mb-1 text-primary transition-colors duration-300">Написание Reels сценариев</h4>
              <p class="text-sm text-primary/60 transition-colors duration-300 group-hover/row:text-primary/80">Пакет от 10 сценариев</p>
            </div>
            <div class="text-xl md:text-2xl lg:text-3xl font-extrabold text-right shrink-0 whitespace-nowrap text-accent">
              3 500 ₽
            </div>
          </div>
          
          <div class="w-full h-px bg-primary/5"></div>
          
          <!-- Item 3 -->
          <div class="stagger-row group/row relative flex justify-between items-center gap-6 p-4 -mx-4 rounded-2xl transition-all duration-300 hover:bg-primary/[0.02] cursor-pointer" style="opacity: 0; transform: translateY(12px);">
            <div class="flex-1 min-w-0">
              <h4 class="text-lg md:text-xl font-bold tracking-tight mb-1 text-primary transition-colors duration-300">Написание постов</h4>
              <p class="text-sm text-primary/60 transition-colors duration-300 group-hover/row:text-primary/80">Комплексно, пакетом 10 шт.</p>
            </div>
            <div class="text-xl md:text-2xl lg:text-3xl font-extrabold text-right shrink-0 whitespace-nowrap text-accent">
              2 000 ₽
            </div>
          </div>
        </div>
      </div>

      <!-- Card 3: Сайты и чат боты (Light Card) -->
      <div class="pricing-card-desktop hidden w-full bg-gradient-to-b from-white to-[#FBF9F4] text-primary rounded-[2.5rem] p-8 md:p-12 border border-primary/5 shadow-[0_30px_80px_-20px_rgba(26,37,48,0.03)] relative overflow-hidden transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]" data-index="2" style="opacity: 0; transform: translateY(6px);">
        <!-- Top Accent Glow Line -->
        <div class="absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r from-accent to-[#942C41]"></div>
        
        <h3 class="text-2xl md:text-3xl font-extrabold text-primary tracking-tight mb-8">Сайты и чат боты</h3>
        <div class="w-full h-px bg-primary/10 mb-6"></div>
        
        <div class="space-y-4">
          <!-- Item: Landing Page -->
          <div class="stagger-row group/row relative flex justify-between items-center gap-6 p-4 -mx-4 rounded-2xl border-[3px] border-accent/50 bg-accent/[0.02] hover:bg-accent/[0.05] shadow-[0_4px_20px_rgba(107,29,47,0.03)] transition-all duration-300 cursor-pointer" style="opacity: 0; transform: translateY(12px);">
            <div class="flex-1 min-w-0">
              <h4 class="text-lg md:text-xl font-bold tracking-tight mb-1 text-primary transition-colors duration-300 flex items-center gap-2">
                Разработка Landing Page
                <span class="px-2 py-0.5 rounded-full bg-accent text-white text-[10px] font-extrabold uppercase tracking-wider shadow-sm select-none">Новинка</span>
              </h4>
              <p class="text-sm text-primary/60 transition-colors duration-300 group-hover/row:text-primary/80">разработка одностраничного сайта с индивидуальным дизайном, адаптивной версткой под мобильные устройства, интеграцией форм и базовым SEO</p>
            </div>
            <div class="text-xl md:text-2xl lg:text-3xl font-extrabold text-right shrink-0 whitespace-nowrap text-accent">
              от 10 000 ₽
            </div>
          </div>

          <div class="w-full h-px bg-primary/5"></div>

          <!-- Item 1 -->
          <div class="stagger-row group/row relative flex justify-between items-center gap-6 p-4 -mx-4 rounded-2xl transition-all duration-300 hover:bg-primary/[0.02] cursor-pointer" style="opacity: 0; transform: translateY(12px);">
            <div class="flex-1 min-w-0">
              <h4 class="text-lg md:text-xl font-bold tracking-tight mb-1 text-primary transition-colors duration-300">Бот для Instagram</h4>
              <p class="text-sm text-primary/60 transition-colors duration-300 group-hover/row:text-primary/80">С лид-магнитом</p>
            </div>
            <div class="text-xl md:text-2xl lg:text-3xl font-extrabold text-right shrink-0 whitespace-nowrap text-accent">
              3 500 ₽ *
            </div>
          </div>
          
          <div class="w-full h-px bg-primary/5"></div>
          
          <!-- Item 2 -->
          <div class="stagger-row group/row relative flex justify-between items-center gap-6 p-4 -mx-4 rounded-2xl transition-all duration-300 hover:bg-primary/[0.02] cursor-pointer" style="opacity: 0; transform: translateY(12px);">
            <div class="flex-1 min-w-0">
              <h4 class="text-lg md:text-xl font-bold tracking-tight mb-1 text-primary transition-colors duration-300">Бот для Telegram</h4>
              <p class="text-sm text-primary/60 transition-colors duration-300 group-hover/row:text-primary/80">С CRM системой</p>
            </div>
            <div class="text-xl md:text-2xl lg:text-3xl font-extrabold text-right shrink-0 whitespace-nowrap text-accent">
              4 000 ₽ **
            </div>
          </div>

          <div class="w-full h-px bg-primary/5"></div>

          <!-- Disclaimer Box -->
          <div class="stagger-row p-6 rounded-2xl bg-background/50 text-primary/85 text-sm md:text-base font-medium space-y-4 mt-6" style="opacity: 0; transform: translateY(12px);">
            <p class="leading-relaxed">
              * 1 500 ₽ написание логики работы бота + 2 000 ₽/мес подписка.
              <br />
              <span class="text-primary/60 font-normal">Бесплатное изменение контента в рамках срока КП. Вне срока — от 1 000 ₽.</span>
            </p>
            <p class="leading-relaxed">
              ** 3 000 ₽ написание логики работы бота + ежемесячная подписка на сервис.
              <br />
              <span class="text-primary/60 font-normal">В первый месяц правки бесплатные. Далее — 500 ₽/правка.</span>
            </p>
          </div>
        </div>
      </div>

      <!-- Card 4: SEO (Light Card) -->
      <div class="pricing-card-desktop hidden w-full bg-gradient-to-b from-white to-[#FBF9F4] text-primary rounded-[2.5rem] p-8 md:p-12 border border-primary/5 shadow-[0_30px_80px_-20px_rgba(26,37,48,0.03)] relative overflow-hidden transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]" data-index="3" style="opacity: 0; transform: translateY(6px);">
        <!-- Top Accent Glow Line -->
        <div class="absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r from-accent to-[#942C41]"></div>
        
        <h3 class="text-2xl md:text-3xl font-extrabold text-primary tracking-tight mb-8">SEO</h3>
        <div class="w-full h-px bg-primary/10 mb-6"></div>
        
        <div class="space-y-4">
          <!-- Item 1 -->
          <div class="stagger-row group/row relative flex justify-between items-center gap-6 p-4 -mx-4 rounded-2xl transition-all duration-300 hover:bg-primary/[0.02] cursor-pointer" style="opacity: 0; transform: translateY(12px);">
            <div class="flex-1 min-w-0">
              <h4 class="text-lg md:text-xl font-bold tracking-tight mb-1 text-primary transition-colors duration-300">Выделение семантического ядра</h4>
              <p class="text-sm text-primary/60 transition-colors duration-300 group-hover/row:text-primary/80">Для сайта и карт</p>
            </div>
            <div class="text-xl md:text-2xl lg:text-3xl font-extrabold text-right shrink-0 whitespace-nowrap text-accent">
              500 ₽
            </div>
          </div>
          
          <div class="w-full h-px bg-primary/5"></div>
          
          <!-- Item 2 -->
          <div class="stagger-row group/row relative flex justify-between items-center gap-6 p-4 -mx-4 rounded-2xl transition-all duration-300 hover:bg-primary/[0.02] cursor-pointer" style="opacity: 0; transform: translateY(12px);">
            <div class="flex-1 min-w-0">
              <h4 class="text-lg md:text-xl font-bold tracking-tight mb-1 text-primary transition-colors duration-300">Локальная SEO оптимизация</h4>
              <p class="text-sm text-primary/60 transition-colors duration-300 group-hover/row:text-primary/80">Яндекс.Карты + 2ГИС</p>
            </div>
            <div class="text-xl md:text-2xl lg:text-3xl font-extrabold text-right shrink-0 whitespace-nowrap text-accent">
              2 500 ₽
            </div>
          </div>
          
          <div class="w-full h-px bg-primary/5"></div>
          
          <!-- Item 3 -->
          <div class="stagger-row group/row relative flex justify-between items-center gap-6 p-4 -mx-4 rounded-2xl transition-all duration-300 hover:bg-primary/[0.02] cursor-pointer" style="opacity: 0; transform: translateY(12px);">
            <div class="flex-1 min-w-0">
              <h4 class="text-lg md:text-xl font-bold tracking-tight mb-1 text-primary transition-colors duration-300">SEO оптимизация сайта</h4>
              <p class="text-sm text-primary/60 transition-colors duration-300 group-hover/row:text-primary/80">Глубокий технический и внутренний аудит</p>
            </div>
            <div class="text-base md:text-lg font-bold text-right shrink-0 text-primary/60 italic">
              Уточняйте у менеджера
            </div>
          </div>
        </div>
      </div>

      <!-- Card 5: Точечные услуги (Light Card) -->
      <div class="pricing-card-desktop hidden w-full bg-gradient-to-b from-white to-[#FBF9F4] text-primary rounded-[2.5rem] p-8 md:p-12 border border-primary/5 shadow-[0_30px_80px_-20px_rgba(26,37,48,0.03)] relative overflow-hidden transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]" data-index="4" style="opacity: 0; transform: translateY(6px);">
        <!-- Top Accent Glow Line -->
        <div class="absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r from-accent to-[#942C41]"></div>
        
        <h3 class="text-2xl md:text-3xl font-extrabold text-primary tracking-tight mb-8">Точечные услуги</h3>
        <div class="w-full h-px bg-primary/10 mb-6"></div>
        
        <div class="space-y-4">
          <!-- Item 1 -->
          <div class="stagger-row group/row relative flex justify-between items-center gap-6 p-4 -mx-4 rounded-2xl transition-all duration-300 hover:bg-primary/[0.02] cursor-pointer" style="opacity: 0; transform: translateY(12px);">
            <div class="flex-1 min-w-0">
              <h4 class="text-lg md:text-xl font-bold tracking-tight mb-1 text-primary transition-colors duration-300">Аудит компании</h4>
              <p class="text-sm text-primary/60 transition-colors duration-300 group-hover/row:text-primary/80">SEO, SMM и консалтинг</p>
            </div>
            <div class="text-xl md:text-2xl lg:text-3xl font-extrabold text-right shrink-0 whitespace-nowrap text-accent">
              1 000 ₽
            </div>
          </div>
          
          <div class="w-full h-px bg-primary/5"></div>
          
          <!-- Item 2 -->
          <div class="stagger-row group/row relative flex justify-between items-center gap-6 p-4 -mx-4 rounded-2xl transition-all duration-300 hover:bg-primary/[0.02] cursor-pointer" style="opacity: 0; transform: translateY(12px);">
            <div class="flex-1 min-w-0">
              <h4 class="text-lg md:text-xl font-bold tracking-tight mb-1 text-primary transition-colors duration-300">Анализ целевой аудитории</h4>
              <p class="text-sm text-primary/60 transition-colors duration-300 group-hover/row:text-primary/80">Глубинный анализ клиентов с выявлением инсайтов и страхов</p>
            </div>
            <div class="text-xl md:text-2xl lg:text-3xl font-extrabold text-right shrink-0 whitespace-nowrap text-accent">
              1 000 ₽
            </div>
          </div>
        </div>
      </div>
      
    </div>

    <!-- CTA Button underneath the pricing block -->
    <div class="flex justify-center mt-12 md:mt-16 reveal">
      <Button id="pricing-cta-desktop" variant="primary" href="#consultation" class="px-10 py-5 text-lg font-extrabold tracking-wider uppercase inline-flex items-center gap-3">
        Получить индивидуальное предложение
        <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
        </svg>
      </Button>
    </div>

  </div>

  <style>
    /* Hide scrollbar for Chrome, Safari and Opera */
    .no-scrollbar::-webkit-scrollbar {
      display: none;
    }
    /* Hide scrollbar for IE, Edge and Firefox */
    .no-scrollbar {
      -ms-overflow-style: none;  /* IE and Edge */
      scrollbar-width: none;  /* Firefox */
    }
  </style>

  <script is:inline>
  (() => {

    document.addEventListener('DOMContentLoaded', () => {
      const tabs = document.querySelectorAll('.pricing-tab-desktop');
      const cards = document.querySelectorAll('.pricing-card-desktop');
      const ctaButton = document.getElementById('pricing-cta-desktop');
      const container = document.getElementById('pricing-cards-container-desktop');

      const INACTIVE_BLUE_CLASSES = "pricing-tab-desktop px-6 py-3 rounded-full border border-primary/10 bg-white/40 backdrop-blur-sm text-primary/70 text-sm font-extrabold transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] whitespace-nowrap cursor-pointer hover:border-primary/30 hover:bg-primary/[0.03] hover:text-primary hover:shadow-[0_6px_15px_rgba(26,37,48,0.04)] active:scale-95 active:opacity-90 select-none";
      const INACTIVE_RED_CLASSES = "pricing-tab-desktop px-6 py-3 rounded-full border border-primary/10 bg-white/40 backdrop-blur-sm text-primary/70 text-sm font-extrabold transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] whitespace-nowrap cursor-pointer hover:border-accent/30 hover:bg-accent/[0.03] hover:text-accent hover:shadow-[0_6px_15px_rgba(107,29,47,0.04)] active:scale-95 active:opacity-90 select-none";
      
      const ACTIVE_BLUE_CLASSES = "pricing-tab-desktop px-6 py-3 rounded-full border border-primary bg-primary text-white text-sm font-extrabold transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] whitespace-nowrap cursor-pointer shadow-[0_10px_25px_rgba(26,37,48,0.12)] active:scale-95 active:opacity-90 select-none";
      const ACTIVE_RED_CLASSES = "pricing-tab-desktop px-6 py-3 rounded-full border border-accent bg-accent text-white text-sm font-extrabold transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] whitespace-nowrap cursor-pointer shadow-[0_10px_25px_rgba(107,29,47,0.15)] active:scale-95 active:opacity-90 select-none";

      // Stagger animation for rows inside active card
      function animateRows(card) {
        if (!card) return;
        const rows = card.querySelectorAll('.stagger-row');
        
        // Reset all rows first
        rows.forEach(row => {
          row.style.opacity = '0';
          row.style.transform = 'translateY(12px)';
          row.style.transition = 'none';
        });

        // Force reflow
        void card.offsetHeight;

        // Animate with stagger delay
        rows.forEach((row, i) => {
          row.style.transition = 'opacity 500ms cubic-bezier(0.16, 1, 0.3, 1), transform 500ms cubic-bezier(0.16, 1, 0.3, 1)';
          setTimeout(() => {
            row.style.opacity = '1';
            row.style.transform = 'translateY(0)';
          }, i * 60); // 60ms delay between rows
        });
      }

      // Update CTA parameters and input fields based on selected category
      function updateCTA(activeCategoryName) {
        if (!ctaButton) return;
        
        ctaButton.onclick = () => {
          const form = document.querySelector('#consultation form');
          if (form) {
            let serviceInput = form.querySelector('input[name="interested_service"]');
            if (!serviceInput) {
              serviceInput = document.createElement('input');
              serviceInput.type = 'hidden';
              serviceInput.name = 'interested_service';
              form.appendChild(serviceInput);
            }
            serviceInput.value = activeCategoryName;
          }
        };
      }

      // Initialize with first tab
      updateCTA("Комплексные решения");

      // Set initial height of container and trigger row stagger animation
      if (container) {
        const activeCard = container.querySelector('.pricing-card-desktop.active');
        if (activeCard) {
          container.style.height = `${activeCard.offsetHeight}px`;
          animateRows(activeCard);
        }
      }

      tabs.forEach((tab, index) => {
        tab.addEventListener('click', () => {
          const activeTab = document.querySelector('.pricing-tab-desktop.bg-primary, .pricing-tab-desktop.bg-accent');
          if (activeTab === tab) return; // Ignore if clicking already active tab

          const categoryName = tab.textContent.trim();
          updateCTA(categoryName);

          // Update active styling of tab buttons
          tabs.forEach(t => {
            const idx = parseInt(t.getAttribute('data-index') || '0', 10);
            const isRed = (idx === 1 || idx === 3);
            t.className = isRed ? INACTIVE_RED_CLASSES : INACTIVE_BLUE_CLASSES;
          });
          
          // Alternating active background colors (indices 0,2,4 -> Blue, indices 1,3 -> Red)
          const idx = parseInt(tab.getAttribute('data-index') || '0', 10);
          const isRed = (idx === 1 || idx === 3);
          tab.className = isRed ? ACTIVE_RED_CLASSES : ACTIVE_BLUE_CLASSES;

          // Find current active card and target card
          const fromCard = container.querySelector('.pricing-card-desktop.active');
          const toCard = Array.from(cards).find(c => parseInt(c.getAttribute('data-index') || '0', 10) === index);

          if (fromCard && toCard) {
            // 1. Lock starting height of container and hide overflow during transition
            const startHeight = fromCard.offsetHeight;
            container.style.height = `${startHeight}px`;
            container.style.overflow = 'hidden';
            
            // Force layout reflow
            void container.offsetHeight;
            container.style.transition = 'height 350ms cubic-bezier(0.16, 1, 0.3, 1)';

            // 2. Fade out current card
            fromCard.style.transition = 'opacity 150ms ease-out, transform 150ms ease-out';
            fromCard.style.opacity = '0';
            fromCard.style.transform = 'translateY(-6px)';

            setTimeout(() => {
              // 3. Swap display states
              fromCard.classList.add('hidden');
              fromCard.classList.remove('active');
              
              toCard.classList.remove('hidden');
              
              // Set starting state for toCard
              toCard.style.opacity = '0';
              toCard.style.transform = 'translateY(6px)';
              toCard.style.transition = 'none';

              // Force reflow
              void toCard.offsetHeight;

              // 4. Measure target height and animate container
              const endHeight = toCard.offsetHeight;
              container.style.height = `${endHeight}px`;

              // 5. Fade in target card
              toCard.style.transition = 'opacity 250ms ease-in, transform 250ms ease-in';
              toCard.style.opacity = '1';
              toCard.style.transform = 'translateY(0)';
              toCard.classList.add('active');

              // Trigger stagger animation for rows inside the newly activated card
              animateRows(toCard);

              // 6. Release container height constraint and restore visible overflow after transition ends
              setTimeout(() => {
                const currentTab = document.querySelector('.pricing-tab-desktop.bg-primary, .pricing-tab-desktop.bg-accent');
                if (currentTab === tab) {
                  container.style.height = '';
                  container.style.transition = '';
                  container.style.overflow = '';
                }
              }, 350);
            }, 150);
          }
        });
      });

      // Update container height on window resize to keep it responsive
      window.addEventListener('resize', () => {
        const activeCard = container.querySelector('.pricing-card-desktop.active');
        if (activeCard && !container.style.transition) {
          container.style.height = '';
        }
      });
    });
  
  })();
</script>
</div>
